#include <ATen/Operators.h>
#include <torch/all.h>
#include <torch/library.h>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"
#include "torch_npu/csrc/core/npu/NPUStream.h"
#include "torch_npu/csrc/framework/OpCommand.h"

namespace extension_cpp {

__global__ void muladd_kernel(int64_t numel, const float* a, const float* b, float c, float* result) {
  int idx = blockIdx.x * blockDim.x + threadIdx.x;
  if (idx < numel) result[idx] = a[idx] * b[idx] + c;
}

at::Tensor mymuladd_npu(const at::Tensor& a, const at::Tensor& b, double c) {
  TORCH_CHECK(a.sizes() == b.sizes());
  TORCH_CHECK(a.dtype() == at::kFloat);
  TORCH_CHECK(b.dtype() == at::kFloat);
  TORCH_INTERNAL_ASSERT(a.device().type() == at::DeviceType::PrivateUse1);
  TORCH_INTERNAL_ASSERT(b.device().type() == at::DeviceType::PrivateUse1);
  at::Tensor a_contig = a.contiguous();
  at::Tensor b_contig = b.contiguous();
  at::Tensor result = at::empty(a_contig.sizes(), a_contig.options());
  const float* a_ptr = a_contig.data_ptr<float>();
  const float* b_ptr = b_contig.data_ptr<float>();
  float* result_ptr = result.data_ptr<float>();

  int64_t numel = a_contig.numel();
  if (numel == 0) return result;
  uint32_t threadsPerBlock = 256;
  uint32_t blocksPerGrid = (numel + threadsPerBlock - 1) / threadsPerBlock;
  uint32_t dyn_ubuf_size = 0;
  auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    muladd_kernel<<<dim3(blocksPerGrid), dim3(threadsPerBlock), dyn_ubuf_size, acl_stream>>>(
        numel, a_ptr, b_ptr, static_cast<float>(c), result_ptr);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2("mymuladd", acl_call);
  return result;
}

__global__ void mul_kernel(int64_t numel, const float* a, const float* b, float* result) {
  int idx = blockIdx.x * blockDim.x + threadIdx.x;
  if (idx < numel) result[idx] = a[idx] * b[idx];
}

at::Tensor mymul_npu(const at::Tensor& a, const at::Tensor& b) {
  TORCH_CHECK(a.sizes() == b.sizes());
  TORCH_CHECK(a.dtype() == at::kFloat);
  TORCH_CHECK(b.dtype() == at::kFloat);
  TORCH_INTERNAL_ASSERT(a.device().type() == at::DeviceType::PrivateUse1);
  TORCH_INTERNAL_ASSERT(b.device().type() == at::DeviceType::PrivateUse1);
  at::Tensor a_contig = a.contiguous();
  at::Tensor b_contig = b.contiguous();
  at::Tensor result = at::empty(a_contig.sizes(), a_contig.options());
  const float* a_ptr = a_contig.data_ptr<float>();
  const float* b_ptr = b_contig.data_ptr<float>();
  float* result_ptr = result.data_ptr<float>();
  int64_t numel = a_contig.numel();
  if (numel == 0) return result;
  uint32_t threadsPerBlock = 256;
  uint32_t blocksPerGrid = (numel + threadsPerBlock - 1) / threadsPerBlock;
  uint32_t dyn_ubuf_size = 0;
  auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    mul_kernel<<<dim3(blocksPerGrid), dim3(threadsPerBlock), dyn_ubuf_size, acl_stream>>>(
        numel, a_ptr, b_ptr, result_ptr);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2("mymul", acl_call);
  return result;
}

__global__ void add_kernel(int64_t numel, const float* a, const float* b, float* result) {
  int idx = blockIdx.x * blockDim.x + threadIdx.x;
  if (idx < numel) result[idx] = a[idx] + b[idx];
}

void myadd_out_npu(const at::Tensor& a, const at::Tensor& b, at::Tensor& out) {
  TORCH_CHECK(a.sizes() == b.sizes());
  TORCH_CHECK(b.sizes() == out.sizes());
  TORCH_CHECK(a.dtype() == at::kFloat);
  TORCH_CHECK(b.dtype() == at::kFloat);
  TORCH_CHECK(out.dtype() == at::kFloat);
  TORCH_CHECK(out.is_contiguous());
  TORCH_INTERNAL_ASSERT(a.device().type() == at::DeviceType::PrivateUse1);
  TORCH_INTERNAL_ASSERT(b.device().type() == at::DeviceType::PrivateUse1);
  TORCH_INTERNAL_ASSERT(out.device().type() == at::DeviceType::PrivateUse1);
  at::Tensor a_contig = a.contiguous();
  at::Tensor b_contig = b.contiguous();
  const float* a_ptr = a_contig.data_ptr<float>();
  const float* b_ptr = b_contig.data_ptr<float>();
  float* result_ptr = out.data_ptr<float>();
  int64_t numel = a_contig.numel();
  if (numel == 0) return;
  uint32_t threadsPerBlock = 256;
  uint32_t blocksPerGrid = (numel + threadsPerBlock - 1) / threadsPerBlock;
  uint32_t dyn_ubuf_size = 0;
  auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    add_kernel<<<dim3(blocksPerGrid), dim3(threadsPerBlock), dyn_ubuf_size, acl_stream>>>(
        numel, a_ptr, b_ptr, result_ptr);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2("myadd_out", acl_call);
}


TORCH_LIBRARY_IMPL(extension_cpp, PrivateUse1, m) {
  m.impl("mymuladd", &mymuladd_npu);
  m.impl("mymul", &mymul_npu);
  m.impl("myadd_out", &myadd_out_npu);
}

}
