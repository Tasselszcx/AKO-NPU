# SessionStart hook for CANNBot (model-infer-optimize) plugin.
#
# On each session start:
#   1. Ensure cann-recipes-infer reference repository exists; clone if missing
#   2. Inject AGENTS.md content as session context (with absolute paths)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
INFER_REPO_DIR="${PLUGIN_ROOT}/cann-recipes-infer"

# --- Step 1: Ensure cann-recipes-infer reference repo is available ---
if [ ! -d "$INFER_REPO_DIR/.git" ]; then
  git clone --quiet --depth 1 https://gitcode.com/cann/cann-recipes-infer.git "$INFER_REPO_DIR" 2>/dev/null || true
fi

# --- Step 1.5: Export INFER_REPO_DIR for Bash tool invocations ---
# Claude Code sources $CLAUDE_ENV_FILE before every Bash command, so this
# makes `$INFER_REPO_DIR` usable in LLM-issued shell commands without needing
# any cwd symlink.
if [ -n "${CLAUDE_ENV_FILE:-}" ] && [ -d "$INFER_REPO_DIR/.git" ]; then
  printf 'export INFER_REPO_DIR=%q\n' "$INFER_REPO_DIR" >> "$CLAUDE_ENV_FILE"
fi

# --- Step 2: Build session context ---
AGENTS_MD="${PLUGIN_ROOT}/AGENTS.md"
if [ ! -f "$AGENTS_MD" ]; then
  exit 0
fi

# Read AGENTS.md, strip frontmatter
agents_content=$(sed -n '/^---$/,/^---$/!p' "$AGENTS_MD" 2>/dev/null || cat "$AGENTS_MD")

# Build path guide — tell the agent where everything actually lives
path_guide="## CANNBot Installation Paths (model-infer-optimize)

All relative references in skills/agents/workflows resolve to absolute paths:
- \`cann-recipes-infer/\` → \`${INFER_REPO_DIR}/\`
- \`skills/\` → \`${PLUGIN_ROOT}/skills/\`
- \`agents/\` → \`${PLUGIN_ROOT}/agents/\`
- \`workflows/\` → \`${PLUGIN_ROOT}/workflows/\`

The shell variable \`\$INFER_REPO_DIR\` is exported for Bash tool calls."

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

path_guide_escaped=$(escape_for_json "$path_guide")
agents_escaped=$(escape_for_json "$agents_content")
session_context="<CANNBOT_CONTEXT>\nYou are CANNBot - NPU Model Inference Optimization Orchestrator.\n\n${path_guide_escaped}\n\n${agents_escaped}\n</CANNBOT_CONTEXT>"

# Output JSON for Claude Code hook system
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
