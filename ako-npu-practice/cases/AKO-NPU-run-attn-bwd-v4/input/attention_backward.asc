// ============================================================================
// Ascend C Kernel - attention_backward
// MIX mode: Cube (Matmul) + Vector computation
// ============================================================================

#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "lib/matmul_intf.h"
#include "data_utils.h"
#include "attention_backward_tiling.h"
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"

typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, bfloat16_t> AType_ND;
typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, bfloat16_t, true> AType_ND_T;
typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, float> CType_F32;
typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, float> BiasType_F32;

constexpr uint32_t UB_BUF_SIZE = 24 * 1024; // 24KB for vector operations (leave room for Matmul)

class KernelAttentionBackward {
public:
    __aicore__ inline KernelAttentionBackward(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(
        GM_ADDR gradAttnOutput, GM_ADDR attnWeights, GM_ADDR attnWeightsDropped,
        GM_ADDR valueStates, GM_ADDR dropoutMask, GM_ADDR gradAttnScores,
        GM_ADDR gradValueStates, GM_ADDR workspace,
        const AttentionBackwardTilingData& tiling)
    {
        tiling_ = tiling;
        gradAttnOutputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(gradAttnOutput));
        attnWeightsGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(attnWeights));
        attnWeightsDroppedGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(attnWeightsDropped));
        valueStatesGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(valueStates));
        dropoutMaskGm_.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(dropoutMask));
        gradAttnScoresGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(gradAttnScores));
        gradValueStatesGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(gradValueStates));
        workspaceAddr_ = workspace;

        // vecBuf_ is initialized in kernel entry before REGIST_MATMUL_OBJ
    }

    __aicore__ inline void Process()
    {
        uint32_t coreIdx = AscendC::GetBlockIdx();
        uint32_t taskStart = coreIdx * tiling_.tasksPerCore;
        uint32_t taskEnd = taskStart + tiling_.tasksPerCore;
        if (taskEnd > tiling_.totalTasks) taskEnd = tiling_.totalTasks;

        uint64_t wsBase = tiling_.wsPerCoreSize * coreIdx;
        wsGradOutGm_.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(
            (GM_ADDR)((uint64_t)workspaceAddr_ + wsBase + tiling_.wsGradOutOffset)));
        wsMm1OutGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(
            (GM_ADDR)((uint64_t)workspaceAddr_ + wsBase + tiling_.wsMm1OutOffset)));
        wsGradVAccGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(
            (GM_ADDR)((uint64_t)workspaceAddr_ + wsBase + tiling_.wsGradVAccOffset)));

        for (uint32_t taskIdx = taskStart; taskIdx < taskEnd; taskIdx++) {
            uint32_t batchIdx = taskIdx / tiling_.numKVHeads;
            uint32_t kvHeadIdx = taskIdx % tiling_.numKVHeads;
            uint32_t headStart = kvHeadIdx * tiling_.numGroups;

            for (uint32_t hLocal = 0; hLocal < tiling_.numGroups; hLocal++) {
                uint32_t h = headStart + hLocal;
                TransposeGradOut(batchIdx, h);
                DoMatmul1(batchIdx, kvHeadIdx);
                DoVectorPhaseB(batchIdx, h);
                DoMatmul2(batchIdx, h, hLocal);
            }
            CastAndWriteGradV(batchIdx, kvHeadIdx);
        }
    }

    AscendC::Matmul<AType_ND, AType_ND_T, CType_F32, BiasType_F32> mm1_;
    AscendC::Matmul<AType_ND_T, AType_ND, CType_F32, BiasType_F32> mm2_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> vecBuf_;

private:
    __aicore__ inline void TransposeGradOut(uint32_t batchIdx, uint32_t headIdx)
    {
        uint32_t seqQ = tiling_.seqLenQ;
        uint32_t headDim = tiling_.headDim;
        uint32_t numHeads = tiling_.numHeads;
        uint64_t batchOff = (uint64_t)batchIdx * seqQ * numHeads * headDim;
        uint32_t rowStride = numHeads * headDim;

        // How many rows fit in UB: each row = 128 * 2 = 256 bytes
        uint32_t maxRows = UB_BUF_SIZE / (headDim * sizeof(bfloat16_t));
        if (maxRows > seqQ) maxRows = seqQ;

        AscendC::LocalTensor<bfloat16_t> ubLocal = vecBuf_.Get<bfloat16_t>();

        for (uint32_t rs = 0; rs < seqQ; rs += maxRows) {
            uint32_t rows = maxRows;
            if (rs + rows > seqQ) rows = seqQ - rs;

            uint64_t srcOff = batchOff + (uint64_t)rs * rowStride + headIdx * headDim;
            AscendC::DataCopyExtParams cpIn;
            cpIn.blockCount = rows;
            cpIn.blockLen = headDim * sizeof(bfloat16_t);
            cpIn.srcStride = (rowStride - headDim) * sizeof(bfloat16_t);
            cpIn.dstStride = 0;
            AscendC::DataCopyPadExtParams<bfloat16_t> padIn(false, 0, 0, (bfloat16_t)0);
            AscendC::DataCopyPad(ubLocal, gradAttnOutputGm_[srcOff], cpIn, padIn);
            AscendC::PipeBarrier<PIPE_MTE2>();

            AscendC::DataCopyExtParams cpOut;
            cpOut.blockCount = rows;
            cpOut.blockLen = headDim * sizeof(bfloat16_t);
            cpOut.srcStride = 0;
            cpOut.dstStride = 0;
            AscendC::DataCopyPad(wsGradOutGm_[(uint64_t)rs * headDim], ubLocal, cpOut);
            AscendC::PipeBarrier<PIPE_MTE3>();
        }
    }

    __aicore__ inline void DoMatmul1(uint32_t batchIdx, uint32_t kvHeadIdx)
    {
        uint64_t vOff = ((uint64_t)batchIdx * tiling_.numKVHeads + kvHeadIdx) * tiling_.seqLenKV * tiling_.headDim;
        mm1_.SetTensorA(wsGradOutGm_);
        mm1_.SetTensorB(valueStatesGm_[vOff], true);
        mm1_.IterateAll(wsMm1OutGm_);
        mm1_.End();
        AscendC::PipeBarrier<PIPE_ALL>();
    }

    __aicore__ inline void DoVectorPhaseB(uint32_t batchIdx, uint32_t headIdx)
    {
        uint32_t seqQ = tiling_.seqLenQ;
        uint32_t seqKV = tiling_.seqLenKV;
        uint32_t numHeads = tiling_.numHeads;
        float dropoutScale = tiling_.dropoutScale;
        uint64_t bhOff = ((uint64_t)batchIdx * numHeads + headIdx) * seqQ * seqKV;

        // Compute aligned sizes
        uint32_t pskv4 = ((seqKV * 4 + 31) / 32) * 32;  // padded bytes for f32
        uint32_t pskv2 = ((seqKV * 2 + 31) / 32) * 32;  // padded bytes for bf16/half
        uint32_t pskv1 = ((seqKV * 1 + 31) / 32) * 32;  // padded bytes for u8

        // Layout in UB (all byte offsets, 32-byte aligned):
        uint32_t off = 0;
        uint32_t oGradAw = off; off += pskv4;     // grad_aw f32
        uint32_t oMaskU8 = off; off += pskv1;     // mask u8
        uint32_t oMaskHalf = off; off += pskv2;   // mask half
        uint32_t oMaskF32 = off; off += pskv4;    // mask f32
        uint32_t oAttnBf16 = off; off += pskv2;   // attn_w bf16
        uint32_t oAttnF32 = off; off += pskv4;    // attn_w f32
        uint32_t oTmp = off; off += pskv4;        // tmp f32
        uint32_t oReduce = off; off += 256;        // reduce workspace
        uint32_t oScalar = off; off += 32;         // scalar
        uint32_t oOutBf16 = off; off += pskv2;    // output bf16
        // Total should fit in UB_BUF_SIZE

        AscendC::LocalTensor<uint8_t> raw = vecBuf_.Get<uint8_t>();
        AscendC::LocalTensor<float> gradAw = raw[oGradAw].ReinterpretCast<float>();
        AscendC::LocalTensor<uint8_t> maskU8 = raw[oMaskU8];
        AscendC::LocalTensor<half> maskHalf = raw[oMaskHalf].ReinterpretCast<half>();
        AscendC::LocalTensor<float> maskF32 = raw[oMaskF32].ReinterpretCast<float>();
        AscendC::LocalTensor<bfloat16_t> attnBf16 = raw[oAttnBf16].ReinterpretCast<bfloat16_t>();
        AscendC::LocalTensor<float> attnF32 = raw[oAttnF32].ReinterpretCast<float>();
        AscendC::LocalTensor<float> tmpBuf = raw[oTmp].ReinterpretCast<float>();
        AscendC::LocalTensor<float> reduceBuf = raw[oReduce].ReinterpretCast<float>();
        AscendC::LocalTensor<float> scalarBuf = raw[oScalar].ReinterpretCast<float>();
        AscendC::LocalTensor<bfloat16_t> outBf16 = raw[oOutBf16].ReinterpretCast<bfloat16_t>();

        for (uint32_t row = 0; row < seqQ; row++) {
            uint64_t rowOff = bhOff + (uint64_t)row * seqKV;

            // Copy in: use DataCopyParams (uint16_t) + DataCopyPadParams
            AscendC::DataCopyPad(gradAw, wsMm1OutGm_[(uint64_t)row * seqKV],
                AscendC::DataCopyParams{1, static_cast<uint16_t>(seqKV * 4), 0, 0},
                AscendC::DataCopyPadParams{false, 0, 0, 0});
            AscendC::DataCopyPad(maskU8, dropoutMaskGm_[rowOff],
                AscendC::DataCopyParams{1, static_cast<uint16_t>(seqKV * 1), 0, 0},
                AscendC::DataCopyPadParams{false, 0, 0, 0});
            AscendC::DataCopyPad(attnBf16, attnWeightsGm_[rowOff],
                AscendC::DataCopyParams{1, static_cast<uint16_t>(seqKV * 2), 0, 0},
                AscendC::DataCopyPadParams{false, 0, 0, 0});
            AscendC::PipeBarrier<PIPE_MTE2>();

            // Dropout backward
            AscendC::Cast<half, uint8_t>(maskHalf, maskU8, AscendC::RoundMode::CAST_NONE, seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::Cast<float, half>(maskF32, maskHalf, AscendC::RoundMode::CAST_NONE, seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::Mul<float>(gradAw, gradAw, maskF32, seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::Muls<float>(gradAw, gradAw, dropoutScale, seqKV);
            AscendC::PipeBarrier<PIPE_V>();

            // Softmax backward
            AscendC::Cast<float, bfloat16_t>(attnF32, attnBf16, AscendC::RoundMode::CAST_NONE, seqKV);
            AscendC::PipeBarrier<PIPE_V>();

            // sum_term = sum(grad_aw * attn_w_f32)
            AscendC::Mul<float>(tmpBuf, gradAw, attnF32, seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::ReduceSum<float>(scalarBuf, tmpBuf, reduceBuf, (int32_t)seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            float sumVal = scalarBuf.GetValue(0);

            // grad_scores = attn_w * (grad_aw - sum_val)
            AscendC::Adds<float>(gradAw, gradAw, -sumVal, seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::Mul<float>(gradAw, attnF32, gradAw, seqKV);
            AscendC::PipeBarrier<PIPE_V>();

            // Cast to bf16 and copy out
            AscendC::Cast<bfloat16_t, float>(outBf16, gradAw, AscendC::RoundMode::CAST_RINT, seqKV);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::DataCopyPad(gradAttnScoresGm_[rowOff], outBf16,
                AscendC::DataCopyParams{1, static_cast<uint16_t>(seqKV * 2), 0, 0});
            AscendC::PipeBarrier<PIPE_MTE3>();
        }
    }

    __aicore__ inline void DoMatmul2(uint32_t batchIdx, uint32_t headIdx, uint32_t hLocal)
    {
        uint64_t awdOff = ((uint64_t)batchIdx * tiling_.numHeads + headIdx) * tiling_.seqLenQ * tiling_.seqLenKV;
        mm2_.SetTensorA(attnWeightsDroppedGm_[awdOff], true);
        mm2_.SetTensorB(wsGradOutGm_);
        uint8_t enAtomic = (hLocal == 0) ? 0 : 1;
        mm2_.IterateAll(wsGradVAccGm_, enAtomic);
        mm2_.End();
        AscendC::PipeBarrier<PIPE_ALL>();
    }

    __aicore__ inline void CastAndWriteGradV(uint32_t batchIdx, uint32_t kvHeadIdx)
    {
        uint32_t seqKV = tiling_.seqLenKV;
        uint32_t headDim = tiling_.headDim;
        uint64_t gvOff = ((uint64_t)batchIdx * tiling_.numKVHeads + kvHeadIdx) * seqKV * headDim;

        // Use UB for cast: f32 + bf16 per element = 6 bytes per element
        uint32_t elemsPerTile = UB_BUF_SIZE / (sizeof(float) + sizeof(bfloat16_t));
        // Align to headDim
        uint32_t rowsPerTile = elemsPerTile / headDim;
        if (rowsPerTile > seqKV) rowsPerTile = seqKV;
        if (rowsPerTile < 1) rowsPerTile = 1;

        uint32_t f32Bytes = ((rowsPerTile * headDim * sizeof(float) + 31) / 32) * 32;

        AscendC::LocalTensor<uint8_t> raw = vecBuf_.Get<uint8_t>();
        AscendC::LocalTensor<float> f32L = raw.ReinterpretCast<float>();
        AscendC::LocalTensor<bfloat16_t> bf16L = raw[f32Bytes].ReinterpretCast<bfloat16_t>();

        for (uint32_t rs = 0; rs < seqKV; rs += rowsPerTile) {
            uint32_t rows = rowsPerTile;
            if (rs + rows > seqKV) rows = seqKV - rs;
            uint32_t count = rows * headDim;

            AscendC::DataCopyPad(f32L, wsGradVAccGm_[(uint64_t)rs * headDim],
                AscendC::DataCopyParams{1, static_cast<uint16_t>(count * 4), 0, 0},
                AscendC::DataCopyPadParams{false, 0, 0, 0});
            AscendC::PipeBarrier<PIPE_MTE2>();

            AscendC::Cast<bfloat16_t, float>(bf16L, f32L, AscendC::RoundMode::CAST_RINT, count);
            AscendC::PipeBarrier<PIPE_V>();

            AscendC::DataCopyPad(gradValueStatesGm_[gvOff + (uint64_t)rs * headDim], bf16L,
                AscendC::DataCopyParams{1, static_cast<uint16_t>(count * 2), 0, 0});
            AscendC::PipeBarrier<PIPE_MTE3>();
        }
    }

    AscendC::TPipe* pipe_;
    AttentionBackwardTilingData tiling_;
    GM_ADDR workspaceAddr_;

    AscendC::GlobalTensor<bfloat16_t> gradAttnOutputGm_;
    AscendC::GlobalTensor<bfloat16_t> attnWeightsGm_;
    AscendC::GlobalTensor<bfloat16_t> attnWeightsDroppedGm_;
    AscendC::GlobalTensor<bfloat16_t> valueStatesGm_;
    AscendC::GlobalTensor<uint8_t> dropoutMaskGm_;
    AscendC::GlobalTensor<bfloat16_t> gradAttnScoresGm_;
    AscendC::GlobalTensor<bfloat16_t> gradValueStatesGm_;

    AscendC::GlobalTensor<bfloat16_t> wsGradOutGm_;
    AscendC::GlobalTensor<float> wsMm1OutGm_;
    AscendC::GlobalTensor<float> wsGradVAccGm_;

};

// ============================================================================
// Kernel Entry
// ============================================================================
extern "C" __global__ __aicore__ void attention_backward_kernel(
    GM_ADDR gradAttnOutput, GM_ADDR attnWeights, GM_ADDR attnWeightsDropped,
    GM_ADDR valueStates, GM_ADDR dropoutMask, GM_ADDR gradAttnScores,
    GM_ADDR gradValueStates, GM_ADDR userWorkspace, GM_ADDR sysWorkspace, GM_ADDR tilingGm)
{
    AttentionBackwardTilingData tilingData;
    {
        auto src = reinterpret_cast<__gm__ uint32_t*>(tilingGm);
        auto dst = reinterpret_cast<uint32_t*>(&tilingData);
        for (uint32_t i = 0; i < sizeof(AttentionBackwardTilingData) / sizeof(uint32_t); i++)
            dst[i] = src[i];
    }
    TCubeTiling mm1Tiling;
    {
        auto src = reinterpret_cast<__gm__ uint32_t*>(tilingGm) + sizeof(AttentionBackwardTilingData) / sizeof(uint32_t);
        auto dst = reinterpret_cast<uint32_t*>(&mm1Tiling);
        for (uint32_t i = 0; i < sizeof(TCubeTiling) / sizeof(uint32_t); i++)
            dst[i] = src[i];
    }
    TCubeTiling mm2Tiling;
    {
        auto src = reinterpret_cast<__gm__ uint32_t*>(tilingGm) + (sizeof(AttentionBackwardTilingData) + sizeof(TCubeTiling)) / sizeof(uint32_t);
        auto dst = reinterpret_cast<uint32_t*>(&mm2Tiling);
        for (uint32_t i = 0; i < sizeof(TCubeTiling) / sizeof(uint32_t); i++)
            dst[i] = src[i];
    }

    AscendC::TPipe pipe;
    KernelAttentionBackward op(&pipe);
    // Use workspaceDevice as the system workspace for Matmul
    // GetSysWorkSpacePtr() should return a valid pointer from the runtime
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), op.mm1_, &mm1Tiling, op.mm2_, &mm2Tiling);
    pipe.InitBuffer(op.vecBuf_, UB_BUF_SIZE);

    // Early exit if no workspace
    if (GetSysWorkSpacePtr() == nullptr) {
        return;
    }
    op.Init(gradAttnOutput, attnWeights, attnWeightsDropped, valueStates,
            dropoutMask, gradAttnScores, gradValueStates, userWorkspace, tilingData);
    op.Process();
}

// ============================================================================
// Host Code
// ============================================================================
struct ArgInfo { std::string fileName; size_t length; };

constexpr uint32_t NUM_ATTENTION_HEADS = 80;
constexpr uint32_t NUM_KEY_VALUE_HEADS = 8;
constexpr uint32_t NUM_KEY_VALUE_GROUPS = 10;
constexpr uint32_t HEAD_DIM = 128;
constexpr float ATTENTION_DROPOUT = 0.1f;

static uint32_t BATCH_SIZE = 4;
static uint32_t SEQ_LEN_Q = 256;
static uint32_t SEQ_LEN_KV = 256;

uint32_t PadTo32(uint32_t count, uint32_t esz) {
    return ((count * esz + 31) / 32) * 32 / esz;
}

void GenTiling(platform_ascendc::PlatformAscendC* plat, uint8_t* buf,
               uint32_t& blkNum, uint64_t& userWs)
{
    auto* td = reinterpret_cast<AttentionBackwardTilingData*>(buf);
    td->batchSize = BATCH_SIZE;
    td->seqLenQ = SEQ_LEN_Q;
    td->seqLenKV = SEQ_LEN_KV;
    td->numHeads = NUM_ATTENTION_HEADS;
    td->numKVHeads = NUM_KEY_VALUE_HEADS;
    td->numGroups = NUM_KEY_VALUE_GROUPS;
    td->headDim = HEAD_DIM;
    td->dropoutScale = 1.0f / (1.0f - ATTENTION_DROPOUT);

    td->totalTasks = BATCH_SIZE * NUM_KEY_VALUE_HEADS;
    int64_t cores = 0;
    aclrtGetDeviceInfo(0, ACL_DEV_ATTR_AICORE_CORE_NUM, &cores);
    if (cores <= 0) cores = 64;
    td->usedCores = (td->totalTasks < (uint32_t)cores) ? td->totalTasks : (uint32_t)cores;
    td->tasksPerCore = (td->totalTasks + td->usedCores - 1) / td->usedCores;
    blkNum = td->usedCores;

    td->paddedSeqKV_f32 = PadTo32(SEQ_LEN_KV, 4);
    td->paddedSeqKV_bf16 = PadTo32(SEQ_LEN_KV, 2);
    td->paddedSeqKV_u8 = PadTo32(SEQ_LEN_KV, 1);
    td->tileRowsVec = 1; // one row at a time for vector phase

    uint64_t wsGO = (uint64_t)SEQ_LEN_Q * HEAD_DIM * 2;
    uint64_t wsM1 = (uint64_t)SEQ_LEN_Q * SEQ_LEN_KV * 4;
    uint64_t wsGV = (uint64_t)SEQ_LEN_KV * HEAD_DIM * 4;
    td->wsGradOutOffset = 0;
    td->wsMm1OutOffset = wsGO;
    td->wsGradVAccOffset = wsGO + wsM1;
    td->wsPerCoreSize = ((wsGO + wsM1 + wsGV + 255) / 256) * 256;
    td->totalWorkspaceSize = td->wsPerCoreSize * td->usedCores;
    userWs = td->totalWorkspaceSize;

    // MM1: A[sq,128]bf16 @ B^T[skv,128]bf16 → C[sq,skv]f32
    {
        matmul_tiling::MatmulApiTiling t(*plat);
        t.SetAType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_BF16, false);
        t.SetBType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_BF16, true);
        t.SetCType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT);
        t.SetBiasType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT);
        t.SetShape(SEQ_LEN_Q, SEQ_LEN_KV, HEAD_DIM);
        t.SetOrgShape(SEQ_LEN_Q, SEQ_LEN_KV, HEAD_DIM);
        t.EnableBias(false);
        t.SetBufferSpace(-1, -1, -1);
        optiling::TCubeTiling td1;
        if (t.GetTiling(td1) == -1) std::cerr << "MM1 tiling fail\n";
        td1.SaveToBuffer(buf + sizeof(AttentionBackwardTilingData), td1.GetDataSize());
    }
    // MM2: A^T[sq,skv]bf16 @ B[sq,128]bf16 → C[skv,128]f32
    {
        matmul_tiling::MatmulApiTiling t(*plat);
        t.SetAType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_BF16, true);
        t.SetBType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_BF16, false);
        t.SetCType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT);
        t.SetBiasType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT);
        t.SetShape(SEQ_LEN_KV, HEAD_DIM, SEQ_LEN_Q);
        t.SetOrgShape(SEQ_LEN_KV, HEAD_DIM, SEQ_LEN_Q);
        t.EnableBias(false);
        t.SetBufferSpace(-1, -1, -1);
        optiling::TCubeTiling td2;
        if (t.GetTiling(td2) == -1) std::cerr << "MM2 tiling fail\n";
        td2.SaveToBuffer(buf + sizeof(AttentionBackwardTilingData) + sizeof(TCubeTiling), td2.GetDataSize());
    }
}

int32_t main(int32_t argc, char* argv[])
{
    if (argc >= 4) { BATCH_SIZE = atoi(argv[1]); SEQ_LEN_Q = atoi(argv[2]); SEQ_LEN_KV = atoi(argv[3]); }
    printf("attention_backward: B=%u sq=%u skv=%u\n", BATCH_SIZE, SEQ_LEN_Q, SEQ_LEN_KV);

    aclInit(nullptr);
    aclrtSetDevice(0);
    auto plat = platform_ascendc::PlatformAscendCManager::GetInstance();

    size_t goSz = (size_t)BATCH_SIZE * SEQ_LEN_Q * NUM_ATTENTION_HEADS * HEAD_DIM * 2;
    size_t awSz = (size_t)BATCH_SIZE * NUM_ATTENTION_HEADS * SEQ_LEN_Q * SEQ_LEN_KV * 2;
    size_t vsSz = (size_t)BATCH_SIZE * NUM_KEY_VALUE_HEADS * SEQ_LEN_KV * HEAD_DIM * 2;
    size_t mkSz = (size_t)BATCH_SIZE * NUM_ATTENTION_HEADS * SEQ_LEN_Q * SEQ_LEN_KV;

    size_t tilSz = sizeof(AttentionBackwardTilingData) + 2 * sizeof(TCubeTiling);
    uint8_t* tilBuf = (uint8_t*)calloc(1, tilSz);
    uint32_t blkNum = 1; uint64_t userWs = 0;
    GenTiling(plat, tilBuf, blkNum, userWs);
    size_t sysWs = (size_t)plat->GetLibApiWorkSpaceSize();
    printf("blkNum=%u userWs=%lu sysWs=%lu\n", blkNum, (unsigned long)userWs, (unsigned long)sysWs);

    aclrtStream stream; aclrtCreateStream(&stream);

    uint8_t *tilDev; aclrtMalloc((void**)&tilDev, tilSz, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilDev, tilSz, tilBuf, tilSz, ACL_MEMCPY_HOST_TO_DEVICE);

    std::vector<ArgInfo> ins = {
        {"./input/grad_attn_output.bin", goSz}, {"./input/attn_weights.bin", awSz},
        {"./input/attn_weights_dropped.bin", awSz}, {"./input/value_states.bin", vsSz},
        {"./input/dropout_mask.bin", mkSz}
    };
    std::vector<ArgInfo> outs = {
        {"./output/grad_attn_scores.bin", awSz}, {"./output/grad_value_states.bin", vsSz}
    };

    std::vector<uint8_t*> iH(ins.size()), iD(ins.size());
    for (size_t i = 0; i < ins.size(); i++) {
        aclrtMallocHost((void**)&iH[i], ins[i].length);
        aclrtMalloc((void**)&iD[i], ins[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile(ins[i].fileName, ins[i].length, iH[i], ins[i].length);
        aclrtMemcpy(iD[i], ins[i].length, iH[i], ins[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }
    std::vector<uint8_t*> oH(outs.size()), oD(outs.size());
    for (size_t i = 0; i < outs.size(); i++) {
        aclrtMallocHost((void**)&oH[i], outs[i].length);
        aclrtMalloc((void**)&oD[i], outs[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }
    uint8_t *userWsDev = nullptr;
    if (userWs > 0) aclrtMalloc((void**)&userWsDev, userWs, ACL_MEM_MALLOC_HUGE_FIRST);
    uint8_t *sysWsDev = nullptr;
    aclrtMalloc((void**)&sysWsDev, sysWs, ACL_MEM_MALLOC_HUGE_FIRST);

    attention_backward_kernel<<<blkNum, nullptr, stream>>>(
        iD[0], iD[1], iD[2], iD[3], iD[4], oD[0], oD[1], userWsDev, sysWsDev, tilDev);
    aclrtSynchronizeStream(stream);

    for (size_t i = 0; i < outs.size(); i++) {
        aclrtMemcpy(oH[i], outs[i].length, oD[i], outs[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile(outs[i].fileName, oH[i], outs[i].length);
    }

    aclrtFree(tilDev);
    if (userWsDev) aclrtFree(userWsDev);
    aclrtFree(sysWsDev);
    for (size_t i = 0; i < ins.size(); i++) { aclrtFree(iD[i]); aclrtFreeHost(iH[i]); }
    for (size_t i = 0; i < outs.size(); i++) { aclrtFree(oD[i]); aclrtFreeHost(oH[i]); }
    aclrtDestroyStream(stream); aclrtResetDevice(0); aclFinalize(); free(tilBuf);
    printf("attention_backward done\n");
    return 0;
}
