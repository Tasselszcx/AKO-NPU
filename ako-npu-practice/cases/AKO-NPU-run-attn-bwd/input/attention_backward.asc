// ============================================================================
// Ascend C Kernel - attention_backward (Vector-only version)
// ============================================================================
// Host precomputes matmul results, kernel does:
// - Phase B: dropout backward + softmax backward
// - Phase D: GQA aggregation
// ============================================================================

#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t NUM_HEADS = 80;
constexpr uint32_t NUM_KV_HEADS = 8;
constexpr uint32_t NUM_GROUPS = 10;
constexpr uint32_t HEAD_DIM = 128;
constexpr float DROPOUT_PROB = 0.1f;
constexpr float DROPOUT_SCALE = 1.0f / (1.0f - DROPOUT_PROB);

struct TilingData {
    uint32_t batch;
    uint32_t seqQ;
    uint32_t seqKv;
    uint32_t usedCoreNum;
};

__aicore__ inline AscendC::DataCopyExtParams MkCp(uint16_t bc, uint32_t bl, uint32_t ss=0, uint32_t ds=0)
{
    AscendC::DataCopyExtParams p; p.blockCount=bc; p.blockLen=bl; p.srcStride=ss; p.dstStride=ds; return p;
}

class KernelAttnBwd {
public:
    __aicore__ inline KernelAttnBwd() {}

    __aicore__ inline void Init(
        GM_ADDR mmResult1,        // [B, 80, sq, skv] float (grad_out @ V^T)
        GM_ADDR attnWeights,      // [B, 80, sq, skv] bf16
        GM_ADDR dropoutMask,      // [B, 80, sq, skv] uint8
        GM_ADDR mmResult2,        // [B, 80, skv, 128] float (attn_dropped^T @ grad_out)
        GM_ADDR gradAttnScores,   // [B, 80, sq, skv] bf16 (output)
        GM_ADDR gradValueStates,  // [B, 8, skv, 128] bf16 (output)
        const __gm__ TilingData* tiling, AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
        blockIdx_ = AscendC::GetBlockIdx();
        batch_ = tiling->batch;
        seqQ_ = tiling->seqQ;
        seqKv_ = tiling->seqKv;
        usedCoreNum_ = tiling->usedCoreNum;
        seqKvAlignF32_ = ((seqKv_ + 7) / 8) * 8;
        seqKvAlignBf16_ = ((seqKv_ + 15) / 16) * 16;

        uint64_t bhsSize = (uint64_t)batch_ * NUM_HEADS * seqQ_ * seqKv_;
        mmResult1Gm_.SetGlobalBuffer((__gm__ float*)mmResult1, bhsSize);
        attnWeightsGm_.SetGlobalBuffer((__gm__ bfloat16_t*)attnWeights, bhsSize);
        uint64_t maskTotalBytes = (uint64_t)batch_ * NUM_HEADS * seqQ_ * ((seqKv_ + 7) / 8);
        dropoutMaskGm_.SetGlobalBuffer((__gm__ uint8_t*)dropoutMask, maskTotalBytes);
        gradAttnScoresGm_.SetGlobalBuffer((__gm__ bfloat16_t*)gradAttnScores, bhsSize);

        uint64_t bhdSize = (uint64_t)batch_ * NUM_HEADS * seqKv_ * HEAD_DIM;
        mmResult2Gm_.SetGlobalBuffer((__gm__ float*)mmResult2, bhdSize);
        uint64_t kvSize = (uint64_t)batch_ * NUM_KV_HEADS * seqKv_ * HEAD_DIM;
        gradValueStatesGm_.SetGlobalBuffer((__gm__ bfloat16_t*)gradValueStates, kvSize);

        // Task distribution: B * 80 heads for Phase B, B * 8 kv_heads for Phase D
        totalBH_ = batch_ * NUM_HEADS;
        totalKV_ = batch_ * NUM_KV_HEADS;

        uint32_t workF32 = seqKvAlignF32_ * sizeof(float);
        uint32_t bf16Row = seqKvAlignBf16_ * sizeof(bfloat16_t);
        // Select mode 1 uses bitmask: seqKv bits = seqKv/8 bytes, align to 32B
        uint32_t maskBytesPerRow = (seqKv_ + 7) / 8;
        uint32_t maskAlign = ((maskBytesPerRow + 31) / 32) * 32;

        pipe_->InitBuffer(inQ1_, 1, workF32);      // mm result float row
        pipe_->InitBuffer(inQ2_, 1, maskAlign);     // dropout mask
        pipe_->InitBuffer(inQ3_, 1, bf16Row);       // attn weights bf16
        pipe_->InitBuffer(outQ1_, 1, bf16Row);      // result bf16
        pipe_->InitBuffer(wb1_, workF32);            // work f32
        pipe_->InitBuffer(wb2_, workF32);            // work f32
        pipe_->InitBuffer(rtBuf_, workF32);          // reduce tmp
        pipe_->InitBuffer(rrBuf_, 32);               // reduce result

        // Phase D buffers
        chunkElems_ = 1024;
        pipe_->InitBuffer(inQD_, 1, chunkElems_ * sizeof(float));
        pipe_->InitBuffer(accBuf_, chunkElems_ * sizeof(float));
        pipe_->InitBuffer(outQD_, 1, chunkElems_ * sizeof(bfloat16_t));
    }

    __aicore__ inline void Process()
    {
        if (blockIdx_ >= usedCoreNum_) return;

        // Phase B: distribute B*80 heads across cores
        uint32_t bhPerCore = totalBH_ / usedCoreNum_;
        uint32_t bhRem = totalBH_ % usedCoreNum_;
        uint32_t bhStart = (blockIdx_ < bhRem) ? blockIdx_ * (bhPerCore+1) : blockIdx_ * bhPerCore + bhRem;
        uint32_t bhEnd = bhStart + bhPerCore + (blockIdx_ < bhRem ? 1 : 0);

        uint32_t maskBytesPerRow = (seqKv_ + 7) / 8;
        for (uint32_t bh = bhStart; bh < bhEnd; bh++) {
            uint64_t bhOff = (uint64_t)bh * seqQ_ * seqKv_;
            uint64_t maskBhOff = (uint64_t)bh * seqQ_ * maskBytesPerRow;
            for (uint32_t q = 0; q < seqQ_; q++) {
                ProcessRow(bhOff + (uint64_t)q * seqKv_,
                           maskBhOff + (uint64_t)q * maskBytesPerRow);
            }
        }

        // No SyncAll needed - Phase B and D are independent per-head

        // Phase D: distribute B*8 kv_heads across cores
        uint32_t kvPerCore = totalKV_ / usedCoreNum_;
        uint32_t kvRem = totalKV_ % usedCoreNum_;
        uint32_t kvStart = (blockIdx_ < kvRem) ? blockIdx_ * (kvPerCore+1) : blockIdx_ * kvPerCore + kvRem;
        uint32_t kvEnd = kvStart + kvPerCore + (blockIdx_ < kvRem ? 1 : 0);

        for (uint32_t bkv = kvStart; bkv < kvEnd; bkv++) {
            uint32_t b = bkv / NUM_KV_HEADS;
            uint32_t kvHead = bkv % NUM_KV_HEADS;
            GQAAggregation(b, kvHead);
        }
    }

private:
    __aicore__ inline void ProcessRow(uint64_t rowOff, uint64_t maskRowOff)
    {
        AscendC::LocalTensor<float> gBuf = inQ1_.AllocTensor<float>();
        AscendC::LocalTensor<uint8_t> mBuf = inQ2_.AllocTensor<uint8_t>();
        AscendC::LocalTensor<bfloat16_t> aBuf = inQ3_.AllocTensor<bfloat16_t>();

        // Load mm result row (float), packed bitmask, attn weights (bf16)
        uint32_t maskBytesPerRow = (seqKv_ + 7) / 8;
        {
            AscendC::DataCopyPadExtParams<float> pp{false, 0, 0, 0};
            AscendC::DataCopyPad(gBuf, mmResult1Gm_[rowOff], MkCp(1, seqKv_ * sizeof(float)), pp);
        }
        {
            AscendC::DataCopyPadExtParams<uint8_t> pp{false, 0, 0, 0};
            AscendC::DataCopyPad(mBuf, dropoutMaskGm_[maskRowOff], MkCp(1, maskBytesPerRow), pp);
        }
        {
            AscendC::DataCopyPadExtParams<bfloat16_t> pp{false, 0, 0, 0};
            AscendC::DataCopyPad(aBuf, attnWeightsGm_[rowOff], MkCp(1, seqKv_ * sizeof(bfloat16_t)), pp);
        }
        inQ1_.EnQue(gBuf); inQ2_.EnQue(mBuf); inQ3_.EnQue(aBuf);

        AscendC::LocalTensor<float> gIn = inQ1_.DeQue<float>();
        AscendC::LocalTensor<uint8_t> mIn = inQ2_.DeQue<uint8_t>();
        AscendC::LocalTensor<bfloat16_t> aIn = inQ3_.DeQue<bfloat16_t>();

        AscendC::LocalTensor<float> w1 = wb1_.Get<float>();
        AscendC::LocalTensor<float> w2 = wb2_.Get<float>();
        AscendC::LocalTensor<float> rT = rtBuf_.Get<float>();
        AscendC::LocalTensor<float> rR = rrBuf_.Get<float>();

        // Cast attn_w bf16 -> f32
        AscendC::Cast<float, bfloat16_t>(w1, aIn, AscendC::RoundMode::CAST_NONE, seqKv_);

        // Dropout backward
        AscendC::Select<float, uint8_t>(gIn, mIn, gIn, (float)0.0f,
            AscendC::SELMODE::VSEL_TENSOR_SCALAR_MODE, seqKv_);
        AscendC::Muls<float>(gIn, gIn, DROPOUT_SCALE, seqKv_);

        // Softmax backward
        AscendC::Mul<float>(w2, gIn, w1, seqKv_);
        AscendC::ReduceSum<float>(rR, w2, rT, static_cast<int32_t>(seqKv_));
        float sumVal = rR.GetValue(0);
        AscendC::Adds<float>(gIn, gIn, -sumVal, seqKv_);
        AscendC::Mul<float>(w2, w1, gIn, seqKv_);

        // Cast f32 -> bf16 and output
        AscendC::LocalTensor<bfloat16_t> rBuf = outQ1_.AllocTensor<bfloat16_t>();
        AscendC::Cast<bfloat16_t, float>(rBuf, w2, AscendC::RoundMode::CAST_ROUND, seqKv_);
        outQ1_.EnQue(rBuf);

        inQ1_.FreeTensor(gIn); inQ2_.FreeTensor(mIn); inQ3_.FreeTensor(aIn);

        AscendC::LocalTensor<bfloat16_t> rOut = outQ1_.DeQue<bfloat16_t>();
        AscendC::DataCopyPad(gradAttnScoresGm_[rowOff], rOut, MkCp(1, seqKv_ * sizeof(bfloat16_t)));
        outQ1_.FreeTensor(rOut);
    }

    __aicore__ inline void GQAAggregation(uint32_t b, uint32_t kvHead)
    {
        uint64_t totalElems = (uint64_t)seqKv_ * HEAD_DIM;
        uint64_t dstOff = (uint64_t)b * NUM_KV_HEADS * seqKv_ * HEAD_DIM + (uint64_t)kvHead * seqKv_ * HEAD_DIM;

        for (uint64_t chunk = 0; chunk < totalElems; chunk += chunkElems_) {
            uint32_t n = (uint32_t)((chunk + chunkElems_ <= totalElems) ? chunkElems_ : (totalElems - chunk));
            AscendC::LocalTensor<float> acc = accBuf_.Get<float>();

            for (uint32_t g = 0; g < NUM_GROUPS; g++) {
                uint32_t h = kvHead * NUM_GROUPS + g;
                uint64_t srcOff = ((uint64_t)b * NUM_HEADS + h) * seqKv_ * HEAD_DIM + chunk;

                AscendC::LocalTensor<float> cBuf = inQD_.AllocTensor<float>();
                AscendC::DataCopyPadExtParams<float> pp{false, 0, 0, 0};
                AscendC::DataCopyPad(cBuf, mmResult2Gm_[srcOff], MkCp(1, n * sizeof(float)), pp);
                inQD_.EnQue(cBuf);
                AscendC::LocalTensor<float> cIn = inQD_.DeQue<float>();

                if (g == 0) AscendC::Adds<float>(acc, cIn, 0.0f, n);
                else AscendC::Add<float>(acc, acc, cIn, n);
                inQD_.FreeTensor(cIn);
            }

            AscendC::LocalTensor<bfloat16_t> oB = outQD_.AllocTensor<bfloat16_t>();
            AscendC::Cast<bfloat16_t, float>(oB, acc, AscendC::RoundMode::CAST_ROUND, n);
            outQD_.EnQue(oB);
            AscendC::LocalTensor<bfloat16_t> oOut = outQD_.DeQue<bfloat16_t>();
            AscendC::DataCopyPad(gradValueStatesGm_[dstOff + chunk], oOut, MkCp(1, n * sizeof(bfloat16_t)));
            outQD_.FreeTensor(oOut);
        }
    }

    AscendC::TPipe* pipe_;
    uint32_t blockIdx_, batch_, seqQ_, seqKv_, usedCoreNum_;
    uint32_t seqKvAlignF32_, seqKvAlignBf16_;
    uint32_t totalBH_, totalKV_, chunkElems_;

    AscendC::GlobalTensor<float> mmResult1Gm_, mmResult2Gm_;
    AscendC::GlobalTensor<bfloat16_t> attnWeightsGm_, gradAttnScoresGm_, gradValueStatesGm_;
    AscendC::GlobalTensor<uint8_t> dropoutMaskGm_;

    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQ1_, inQ2_, inQ3_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQ1_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> wb1_, wb2_, rtBuf_, rrBuf_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQD_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> accBuf_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQD_;
};

extern "C" __global__ __vector__ void attention_backward_kernel(
    GM_ADDR mmResult1, GM_ADDR attnWeights, GM_ADDR dropoutMask,
    GM_ADDR mmResult2, GM_ADDR gradAttnScores, GM_ADDR gradValueStates,
    GM_ADDR tilingGm)
{
    AscendC::TPipe pipe;
    KernelAttnBwd op;
    op.Init(mmResult1, attnWeights, dropoutMask, mmResult2,
            gradAttnScores, gradValueStates,
            (__gm__ TilingData*)tilingGm, &pipe);
    op.Process();
}

// ============================================================================
// Host side
// ============================================================================
struct ArgInfo { std::string fileName; size_t length; };

int32_t main(int32_t argc, char* argv[])
{
    uint32_t batch = 4, seqQ = 256, seqKv = 256;
    if (argc >= 4) { batch = atoi(argv[1]); seqQ = atoi(argv[2]); seqKv = atoi(argv[3]); }
    printf("attention_backward: batch=%u, seqQ=%u, seqKv=%u\n", batch, seqQ, seqKv);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);

    int64_t coreNum = 0;
    aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &coreNum);
    printf("AI Cores: %ld\n", coreNum);

    TilingData tiling;
    tiling.batch = batch;
    tiling.seqQ = seqQ;
    tiling.seqKv = seqKv;
    uint32_t totalTasks = batch * NUM_HEADS;  // max of B*80 and B*8
    tiling.usedCoreNum = (totalTasks < (uint32_t)coreNum) ? totalTasks : (uint32_t)coreNum;
    uint32_t blockNum = tiling.usedCoreNum;
    printf("Using %u cores\n", blockNum);

    size_t bhsF32 = (size_t)batch * NUM_HEADS * seqQ * seqKv * sizeof(float);
    size_t bhsBf16 = (size_t)batch * NUM_HEADS * seqQ * seqKv * sizeof(uint16_t);
    // Packed bitmask: seqKv bits per row, seqQ * B * 80 rows
    uint32_t maskBytesPerRow = (seqKv + 7) / 8;
    size_t bhsU8 = (size_t)batch * NUM_HEADS * seqQ * maskBytesPerRow;
    size_t bhdF32 = (size_t)batch * NUM_HEADS * seqKv * HEAD_DIM * sizeof(float);
    size_t kvBf16 = (size_t)batch * NUM_KV_HEADS * seqKv * HEAD_DIM * sizeof(uint16_t);

    std::vector<ArgInfo> inputs = {
        {"./input/mm_result1.bin", bhsF32},      // [B,80,sq,skv] float
        {"./input/attn_weights.bin", bhsBf16},    // [B,80,sq,skv] bf16
        {"./input/dropout_mask.bin", bhsU8},      // [B,80,sq,skv] uint8
        {"./input/mm_result2.bin", bhdF32},       // [B,80,skv,128] float
    };
    std::vector<ArgInfo> outputs = {
        {"./output/grad_attn_scores.bin", bhsBf16},
        {"./output/grad_value_states.bin", kvBf16},
    };

    uint8_t *tD = nullptr;
    aclrtMalloc((void**)&tD, sizeof(TilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tD, sizeof(TilingData), &tiling, sizeof(TilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    std::vector<uint8_t*> iH(inputs.size()), iD(inputs.size());
    std::vector<uint8_t*> oH(outputs.size()), oD(outputs.size());

    for (size_t i = 0; i < inputs.size(); i++) {
        aclrtMallocHost((void**)&iH[i], inputs[i].length);
        aclrtMalloc((void**)&iD[i], inputs[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile(inputs[i].fileName, inputs[i].length, iH[i], inputs[i].length);
        aclrtMemcpy(iD[i], inputs[i].length, iH[i], inputs[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }
    for (size_t i = 0; i < outputs.size(); i++) {
        aclrtMallocHost((void**)&oH[i], outputs[i].length);
        aclrtMalloc((void**)&oD[i], outputs[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    attention_backward_kernel<<<blockNum, nullptr, stream>>>(
        iD[0], iD[1], iD[2], iD[3], oD[0], oD[1], tD);
    auto ret = aclrtSynchronizeStream(stream);
    if (ret != ACL_SUCCESS) printf("ERROR: sync failed, code=%d\n", ret);
    else printf("Kernel completed successfully.\n");

    for (size_t i = 0; i < outputs.size(); i++) {
        aclrtMemcpy(oH[i], outputs[i].length, oD[i], outputs[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile(outputs[i].fileName, oH[i], outputs[i].length);
    }

    aclrtFree(tD);
    for (size_t i = 0; i < outputs.size(); i++) { aclrtFree(oD[i]); aclrtFreeHost(oH[i]); }
    for (size_t i = 0; i < inputs.size(); i++) { aclrtFree(iD[i]); aclrtFreeHost(iH[i]); }
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    printf("Done.\n");
    return 0;
}
