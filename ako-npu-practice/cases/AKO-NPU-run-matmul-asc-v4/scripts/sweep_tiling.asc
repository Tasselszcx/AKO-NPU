#include <iostream>
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"

int main() {
    const char *socVersion = "Ascend910B1";
    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance(socVersion);

    using TPosition = matmul_tiling::TPosition;
    using CubeFormat = matmul_tiling::CubeFormat;
    using DataType = matmul_tiling::DataType;

    int M = 1024, N = 640, K = 256;
    int baseMList[] = {64, 128, 256, 512, 1024};
    int baseNList[] = {64, 128, 256, 320, 640};
    int coreList[] = {1, 2, 4, 5, 8, 10, 16, 20};

    for (int c = 0; c < 8; c++) {
        for (int bm = 0; bm < 5; bm++) {
            for (int bn = 0; bn < 5; bn++) {
                int cores = coreList[c];
                int baseM = baseMList[bm];
                int baseN = baseNList[bn];

                matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);
                tilingApi.SetDim(cores);
                tilingApi.SetAType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT16, false);
                tilingApi.SetBType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT16, false);
                tilingApi.SetCType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT);
                tilingApi.SetBiasType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT);
                tilingApi.SetOrgShape(M, N, K);
                tilingApi.SetShape(M, N, K);
                tilingApi.SetBias(true);
                tilingApi.SetTraverse(matmul_tiling::MatrixTraverse::FIRSTM);
                tilingApi.SetFixSplit(baseM, baseN, -1);
                tilingApi.SetBufferSpace(-1, -1, -1);

                AscendC::tiling::TCubeTiling td;
                int64_t res = tilingApi.GetTiling(td);
                if (res != -1) {
                    std::cout << "OK: cores=" << cores << " baseM=" << baseM << " baseN=" << baseN
                              << " singleCoreM=" << td.singleCoreM << " singleCoreN=" << td.singleCoreN << std::endl;
                }
            }
        }
    }
    return 0;
}
