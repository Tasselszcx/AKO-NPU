// ============================================================================
// vae_residual_block - Multi-kernel VAE Residual Block
// Pipeline: Im2Col -> WeightTranspose -> Matmul -> Transpose(NHWC->NCHW)
//           -> GroupNorm -> SiLU -> (repeat) -> ResidualAdd
// ============================================================================

#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"
#define ASCENDC_CUBE_ONLY
#include "lib/matmul_intf.h"

// ============================================================================
// Tiling Data Structures
// ============================================================================

// Custom tiling data passed via GM to vector kernels
struct VecKernelTiling {
    uint32_t B;
    uint32_t C;
    uint32_t H;
    uint32_t W;
    uint32_t numCores;
    uint32_t KH;        // kernel height = 3
    uint32_t KW;        // kernel width = 3
    uint32_t pad;        // padding = 1
    uint32_t numGroups;  // 32
    float epsilon;       // 1e-5
};

// GroupNorm tiling passed separately - following the official groupnorm example pattern
namespace optiling {
BEGIN_TILING_DATA_DEF(GNTilingDataDef)
TILING_DATA_FIELD_DEF_STRUCT(GroupNormTiling, gnTilingData);
TILING_DATA_FIELD_DEF(uint32_t, groupNum);
TILING_DATA_FIELD_DEF(float, epsilon);
TILING_DATA_FIELD_DEF(uint32_t, stackSize);
END_TILING_DATA_DEF;
REGISTER_TILING_DATA_CLASS(GNCustom, GNTilingDataDef)
}

// Kernel-side struct matching the tiling definition
struct GNTilingKernel {
    GroupNormTiling gnTiling;
    uint32_t groupNum;
    float epsilon;
    uint32_t stackSize;
};

// ============================================================================
// Kernel 1: Im2Col (Vector)
// NCHW [B,C,H,W] -> [B*H*W, C*KH*KW]
// ============================================================================
class KernelIm2Col {
public:
    __aicore__ inline KernelIm2Col(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR input, GM_ADDR output,
                                const VecKernelTiling& t)
    {
        B_ = t.B; C_ = t.C; H_ = t.H; W_ = t.W;
        uint32_t totalRows = B_ * H_ * W_;
        uint32_t coreId = AscendC::GetBlockIdx();
        if (coreId >= t.numCores) { rowCount_ = 0; return; }

        uint32_t rowsPerCore = (totalRows + t.numCores - 1) / t.numCores;
        startRow_ = coreId * rowsPerCore;
        uint32_t endRow = startRow_ + rowsPerCore;
        if (endRow > totalRows) endRow = totalRows;
        rowCount_ = endRow - startRow_;
        if (rowCount_ == 0) return;

        colWidth_ = C_ * 9;  // C * KH * KW
        inputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(input), B_ * C_ * H_ * W_);
        outputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(output), totalRows * colWidth_);

        // UB: one row of W floats for reading input channel row, one output row
        uint32_t colWidthAlign = (colWidth_ + 7) / 8 * 8;
        uint32_t wAlign = (W_ + 7) / 8 * 8;
        pipe_->InitBuffer(outBuf_, 1, colWidthAlign * sizeof(float));
        pipe_->InitBuffer(tmpQue_, 1, wAlign * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        for (uint32_t r = 0; r < rowCount_; r++) {
            ProcessRow(startRow_ + r);
        }
    }

private:
    __aicore__ inline void ProcessRow(uint32_t row)
    {
        uint32_t b = row / (H_ * W_);
        uint32_t hw = row % (H_ * W_);
        uint32_t h = hw / W_;
        uint32_t w = hw % W_;

        AscendC::LocalTensor<float> colLocal = outBuf_.AllocTensor<float>();
        uint32_t colWidthAlign = (colWidth_ + 7) / 8 * 8;
        // Pre-fill zeros for padding
        AscendC::Duplicate<float>(colLocal, 0.0f, colWidthAlign);
        AscendC::PipeBarrier<PIPE_ALL>();

        for (uint32_t c = 0; c < C_; c++) {
            for (int32_t kh = -1; kh <= 1; kh++) {
                int32_t ih = (int32_t)h + kh;
                if (ih < 0 || ih >= (int32_t)H_) continue;

                // Determine valid kw range
                int32_t kwStart = (w == 0) ? 0 : -1;
                int32_t kwEnd = (w >= W_ - 1) ? 0 : 1;
                int32_t validCount = kwEnd - kwStart + 1;

                // GM offset: input[b, c, ih, w+kwStart]
                uint32_t gmOff = b * C_ * H_ * W_ + c * H_ * W_ + (uint32_t)ih * W_ + (w + kwStart);
                // Read valid_count floats from GM using VECIN queue
                AscendC::LocalTensor<float> tmpLocal = tmpQue_.AllocTensor<float>();
                AscendC::DataCopyExtParams readP{1, (uint32_t)(validCount * sizeof(float)), 0, 0, 0};
                AscendC::DataCopyPadExtParams<float> padP{false, 0, 0, 0.0f};
                AscendC::DataCopyPad(tmpLocal, inputGm_[gmOff], readP, padP);
                tmpQue_.EnQue(tmpLocal);
                tmpLocal = tmpQue_.DeQue<float>();

                // Copy to correct position in colLocal using scalar ops
                uint32_t colOff = c * 9 + (kh + 1) * 3 + (kwStart + 1);
                for (int32_t i = 0; i < validCount; i++) {
                    colLocal.SetValue(colOff + i, tmpLocal.GetValue(i));
                }
                tmpQue_.FreeTensor(tmpLocal);
            }
        }

        // Write row to GM
        AscendC::DataCopyExtParams writeP{1, colWidth_ * (uint32_t)sizeof(float), 0, 0, 0};
        AscendC::DataCopyPad(outputGm_[row * colWidth_], colLocal, writeP);
        AscendC::PipeBarrier<PIPE_ALL>();
        outBuf_.FreeTensor(colLocal);
    }

    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<float> inputGm_;
    AscendC::GlobalTensor<float> outputGm_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outBuf_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> tmpQue_;
    uint32_t B_, C_, H_, W_;
    uint32_t startRow_, rowCount_, colWidth_;
};

// ============================================================================
// Kernel 2: Weight Transpose (Vector)
// [C_out, C_in*KH*KW] = [256, 2304] -> [C_in*KH*KW, C_out] = [2304, 256]
// ============================================================================
class KernelWeightTranspose {
public:
    __aicore__ inline KernelWeightTranspose(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR weight, GM_ADDR weightT,
                                const VecKernelTiling& t)
    {
        rows_ = t.C;           // 256 (C_out)
        cols_ = t.C * 9;      // 2304 (C_in * KH * KW)
        constexpr uint32_t TILE_ROWS = 8;
        tileRows_ = TILE_ROWS;
        uint32_t colsAlign = (cols_ + 7) / 8 * 8;
        uint32_t tileRowsAlign = (tileRows_ + 7) / 8 * 8;

        // InitBuffer: read TILE_ROWS rows of cols_ floats into UB
        // Total: 8 * 2304 * 4 = 73,728 bytes + 32 bytes ≈ 72KB
        pipe_->InitBuffer(inBuf_, 1, tileRows_ * colsAlign * sizeof(float));
        pipe_->InitBuffer(outSmallQue_, 1, tileRowsAlign * sizeof(float));

        uint32_t coreId = AscendC::GetBlockIdx();
        if (coreId >= t.numCores) { tileCount_ = 0; return; }

        uint32_t totalTiles = (rows_ + TILE_ROWS - 1) / TILE_ROWS;
        uint32_t tilesPerCore = (totalTiles + t.numCores - 1) / t.numCores;
        startTile_ = coreId * tilesPerCore;
        uint32_t endTile = startTile_ + tilesPerCore;
        if (endTile > totalTiles) endTile = totalTiles;
        tileCount_ = endTile - startTile_;
        if (tileCount_ == 0) return;

        weightGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(weight), rows_ * cols_);
        weightTGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(weightT), cols_ * rows_);
    }

    __aicore__ inline void Process()
    {
        for (uint32_t t = 0; t < tileCount_; t++) {
            ProcessTile(startTile_ + t);
        }
    }

private:
    __aicore__ inline void ProcessTile(uint32_t tileIdx)
    {
        uint32_t rowStart = tileIdx * tileRows_;
        uint32_t numRows = tileRows_;
        if (rowStart + numRows > rows_) numRows = rows_ - rowStart;

        AscendC::LocalTensor<float> tileBuf = inBuf_.AllocTensor<float>();
        uint32_t colsAlign = (cols_ + 7) / 8 * 8;

        // Read numRows rows from GM, each row = cols_ floats
        for (uint32_t i = 0; i < numRows; i++) {
            AscendC::DataCopyExtParams rp{1, cols_ * (uint32_t)sizeof(float), 0, 0, 0};
            AscendC::DataCopyPadExtParams<float> pp{false, 0, 0, 0.0f};
            AscendC::DataCopyPad(tileBuf[i * colsAlign], weightGm_[(rowStart + i) * cols_], rp, pp);
        }
        AscendC::PipeBarrier<PIPE_ALL>();

        // Transpose: for each column j in source (=row j in output)
        // Use a single alloc/free cycle with PipeBarrier for synchronization
        AscendC::LocalTensor<float> outRow = outSmallQue_.AllocTensor<float>();
        for (uint32_t j = 0; j < cols_; j++) {
            // Extract column j from tileBuf
            for (uint32_t i = 0; i < numRows; i++) {
                outRow.SetValue(i, tileBuf.GetValue(i * colsAlign + j));
            }
            AscendC::PipeBarrier<PIPE_ALL>();
            // Write numRows floats to weightT[j, rowStart]
            AscendC::DataCopyExtParams wp{1, numRows * (uint32_t)sizeof(float), 0, 0, 0};
            AscendC::DataCopyPad(weightTGm_[j * rows_ + rowStart], outRow, wp);
            AscendC::PipeBarrier<PIPE_ALL>();
        }
        outSmallQue_.FreeTensor(outRow);
        inBuf_.FreeTensor(tileBuf);
    }

    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<float> weightGm_;
    AscendC::GlobalTensor<float> weightTGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inBuf_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outSmallQue_;
    uint32_t rows_, cols_;
    uint32_t startTile_, tileCount_, tileRows_;
};

// ============================================================================
// Kernel 3: Matmul (Cube)
// A=[B*H*W, 2304] x B=[2304, 256] -> C=[B*H*W, 256]
// ============================================================================
__aicore__ inline void CopyTiling(TCubeTiling* tiling, GM_ADDR tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);
    for (uint32_t i = 0; i < sizeof(TCubeTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
}

template <typename AType, typename BType, typename CType>
class KernelMatmul {
public:
    __aicore__ inline KernelMatmul() {}

    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c, const TCubeTiling& t)
    {
        tiling_ = t;
        aGm_.SetGlobalBuffer(reinterpret_cast<__gm__ AType*>(a), tiling_.M * tiling_.Ka);
        bGm_.SetGlobalBuffer(reinterpret_cast<__gm__ BType*>(b), tiling_.Kb * tiling_.N);
        cGm_.SetGlobalBuffer(reinterpret_cast<__gm__ CType*>(c), tiling_.M * tiling_.N);

        int32_t blockIdx = AscendC::GetBlockIdx();
        auto mBlocks = (tiling_.M + tiling_.singleCoreM - 1) / tiling_.singleCoreM;
        auto mIdx = blockIdx % mBlocks;
        auto nIdx = blockIdx / mBlocks;

        int32_t offA = mIdx * tiling_.Ka * tiling_.singleCoreM;
        int32_t offB = nIdx * tiling_.singleCoreN;
        int32_t offC = mIdx * tiling_.N * tiling_.singleCoreM + nIdx * tiling_.singleCoreN;

        aGm_ = aGm_[offA];
        bGm_ = bGm_[offB];
        cGm_ = cGm_[offC];

        int tailM = tiling_.M - mIdx * tiling_.singleCoreM;
        tailM = tailM < tiling_.singleCoreM ? tailM : tiling_.singleCoreM;
        int tailN = tiling_.N - nIdx * tiling_.singleCoreN;
        tailN = tailN < tiling_.singleCoreN ? tailN : tiling_.singleCoreN;
        if (tailM < tiling_.singleCoreM || tailN < tiling_.singleCoreN) {
            mm_.SetTail(tailM, tailN);
        }
    }

    __aicore__ inline void Process(AscendC::TPipe* pipe)
    {
        mm_.SetTensorA(aGm_);
        mm_.SetTensorB(bGm_);
        mm_.IterateAll(cGm_);
        mm_.End();
    }

    AscendC::Matmul<AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, AType>,
                    AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, BType>,
                    AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, CType>> mm_;

private:
    AscendC::GlobalTensor<AType> aGm_;
    AscendC::GlobalTensor<BType> bGm_;
    AscendC::GlobalTensor<CType> cGm_;
    TCubeTiling tiling_;
};

// ============================================================================
// Kernel 4: Transpose NHWC->NCHW (Vector)
// [B*H*W, C] -> [B, C, H, W]
// ============================================================================
class KernelTransposeNHWC2NCHW {
public:
    __aicore__ inline KernelTransposeNHWC2NCHW(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR input, GM_ADDR output,
                                const VecKernelTiling& t)
    {
        B_ = t.B; C_ = t.C; H_ = t.H; W_ = t.W;

        // UB layout: inBuf holds a tile of NHWC rows [tileHW * cAlign floats],
        //            outBuf holds extracted channel data [tileHWAlign floats]
        // UB budget: 192KB total, reserve ~16KB for TPipe overhead
        uint32_t totalHW = H_ * W_;
        uint32_t cAlign = (C_ + 7) / 8 * 8;
        uint32_t ubBudget = 176 * 1024;  // reserve 16KB for TPipe overhead
        tileHW_ = ubBudget / ((cAlign + 1) * sizeof(float));
        // Align down to 8 for float32 alignment
        tileHW_ = (tileHW_ / 8) * 8;
        if (tileHW_ == 0) tileHW_ = 8;
        if (tileHW_ > totalHW) tileHW_ = totalHW;
        uint32_t tileHWAlign = (tileHW_ + 7) / 8 * 8;

        // All cores must call InitBuffer for consistent TPipe state
        pipe_->InitBuffer(inBuf_, 1, tileHW_ * cAlign * sizeof(float));
        pipe_->InitBuffer(outBuf_, 1, tileHWAlign * sizeof(float));

        uint32_t totalCh = C_;
        uint32_t coreId = AscendC::GetBlockIdx();
        if (coreId >= t.numCores) { chCount_ = 0; return; }

        uint32_t chPerCore = (totalCh + t.numCores - 1) / t.numCores;
        startCh_ = coreId * chPerCore;
        if (startCh_ >= totalCh) { chCount_ = 0; return; }
        uint32_t endCh = startCh_ + chPerCore;
        if (endCh > totalCh) endCh = totalCh;
        chCount_ = endCh - startCh_;
        if (chCount_ == 0) return;

        inputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(input), B_ * H_ * W_ * C_);
        outputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(output), B_ * C_ * H_ * W_);
    }

    __aicore__ inline void Process()
    {
        if (chCount_ == 0) return;
        uint32_t totalHW = H_ * W_;
        uint32_t cAlign = (C_ + 7) / 8 * 8;

        for (uint32_t b = 0; b < B_; b++) {
            for (uint32_t hwStart = 0; hwStart < totalHW; hwStart += tileHW_) {
                uint32_t numHW = tileHW_;
                if (hwStart + numHW > totalHW) numHW = totalHW - hwStart;

                // CopyIn: read numHW NHWC rows into inBuf
                // Each row = C floats, contiguous in GM
                AscendC::LocalTensor<float> inLocal = inBuf_.AllocTensor<float>();
                // Read numHW rows, each row C floats, padded to cAlign in UB
                AscendC::DataCopyExtParams rp{
                    (uint16_t)numHW,                           // blockCount: number of rows
                    C_ * (uint32_t)sizeof(float),              // blockLen: C*4 bytes per row
                    0,                                         // srcStride: 0 (rows contiguous in GM)
                    (uint32_t)((cAlign - C_) * sizeof(float) / 32),  // dstStride: padding to cAlign (UB, unit=32B)
                    0
                };
                uint32_t gmSrcOff = (b * totalHW + hwStart) * C_;
                AscendC::DataCopyPadExtParams<float> pp{false, 0, 0, 0.0f};
                AscendC::DataCopyPad(inLocal, inputGm_[gmSrcOff], rp, pp);
                AscendC::PipeBarrier<PIPE_ALL>();

                // For each channel assigned to this core, extract from inLocal and write to output
                for (uint32_t ci = 0; ci < chCount_; ci++) {
                    uint32_t c = startCh_ + ci;
                    AscendC::LocalTensor<float> outLocal = outBuf_.AllocTensor<float>();

                    // Extract channel c from each of the numHW rows via scalar ops
                    for (uint32_t i = 0; i < numHW; i++) {
                        outLocal.SetValue(i, inLocal.GetValue(i * cAlign + c));
                    }
                    AscendC::PipeBarrier<PIPE_ALL>();

                    // Write to NCHW output: output[b, c, hwStart..hwStart+numHW]
                    uint32_t gmDstOff = b * C_ * totalHW + c * totalHW + hwStart;
                    AscendC::DataCopyExtParams wp{1, numHW * (uint32_t)sizeof(float), 0, 0, 0};
                    AscendC::DataCopyPad(outputGm_[gmDstOff], outLocal, wp);
                    AscendC::PipeBarrier<PIPE_ALL>();

                    outBuf_.FreeTensor(outLocal);
                }

                inBuf_.FreeTensor(inLocal);
            }
        }
    }

private:
    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<float> inputGm_;
    AscendC::GlobalTensor<float> outputGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inBuf_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outBuf_;
    uint32_t B_, C_, H_, W_;
    uint32_t startCh_, chCount_, tileHW_;
};

// ============================================================================
// Kernel 5: GroupNorm (Vector) - manual implementation
// Computes: output = gamma * (x - mean) / sqrt(var + eps) + beta
// where mean and var are computed over (cpg * H * W) elements per group
// ============================================================================
class KernelGroupNorm {
public:
    __aicore__ inline KernelGroupNorm(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR input, GM_ADDR gamma, GM_ADDR beta,
                                GM_ADDR output, GM_ADDR workspace,
                                const VecKernelTiling& t,
                                const GNTilingKernel& gnTData)
    {
        B_ = t.B; C_ = t.C; H_ = t.H; W_ = t.W;
        G_ = t.numGroups;
        epsilon_ = gnTData.epsilon;
        cpg_ = C_ / G_;  // channels per group = 8
        uint32_t HW = H_ * W_;
        // Pre-compute inverse count: stored as float constant in tiling data
        // gnTData.stackSize contains invCount as float bits (reinterpreted from host)
        // Actually, let's use the stackSize field to pass invCount
        invCount_ = *reinterpret_cast<const float*>(&gnTData.stackSize);

        inputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(input), B_ * C_ * HW);
        gammaGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(gamma), C_);
        betaGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(beta), C_);
        outputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(output), B_ * C_ * HW);

        // UB: process one channel's spatial data at a time (H*W floats)
        // Need: inBuf (data tile), outBuf (output tile), tmpBuf (reduce workspace)
        // tileSize = HW up to 12K floats max (48KB) to leave room for other buffers
        tileSize_ = HW;
        uint32_t maxTile = 12288;  // 48KB per buffer
        if (tileSize_ > maxTile) tileSize_ = maxTile;
        uint32_t tileAlign = (tileSize_ + 7) / 8 * 8;

        pipe_->InitBuffer(inBuf_, 1, tileAlign * sizeof(float));
        pipe_->InitBuffer(outBuf_, 1, tileAlign * sizeof(float));
        // Reduce temp buffer: ceil(tileSize/64)*8 floats for ReduceSum sharedTmpBuffer
        uint32_t reduceElements = ((tileSize_ + 63) / 64) * 8;
        if (reduceElements < 8) reduceElements = 8;
        pipe_->InitBuffer(reduceBuf_, reduceElements * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        if (AscendC::GetBlockIdx() != 0) return;
        uint32_t HW = H_ * W_;

        for (uint32_t b = 0; b < B_; b++) {
            for (uint32_t g = 0; g < G_; g++) {
                // Compute mean over cpg*HW elements
                float sum = 0.0f;
                uint32_t gmGroupOff = b * C_ * HW + g * cpg_ * HW;

                // Pass 1: compute sum for mean
                for (uint32_t c = 0; c < cpg_; c++) {
                    uint32_t gmChOff = gmGroupOff + c * HW;
                    for (uint32_t start = 0; start < HW; start += tileSize_) {
                        uint32_t len = tileSize_;
                        if (start + len > HW) len = HW - start;
                        uint32_t lenAlign = (len + 7) / 8 * 8;

                        AscendC::LocalTensor<float> inLocal = inBuf_.AllocTensor<float>();
                        AscendC::DataCopyExtParams rp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
                        AscendC::DataCopyPadExtParams<float> pp{true, 0, 0, 0.0f};
                        AscendC::DataCopyPad(inLocal, inputGm_[gmChOff + start], rp, pp);
                        inBuf_.EnQue(inLocal);
                        inLocal = inBuf_.DeQue<float>();

                        // Vector reduce sum for better precision
                        AscendC::LocalTensor<float> reduceLocal = reduceBuf_.Get<float>();
                        AscendC::ReduceSum(inLocal, inLocal, reduceLocal, len);
                        AscendC::PipeBarrier<PIPE_ALL>();
                        sum += inLocal.GetValue(0);

                        inBuf_.FreeTensor(inLocal);
                    }
                }
                float mean = sum * invCount_;

                // Pass 2: compute variance sum = sum((x - mean)^2)
                float varSum = 0.0f;
                for (uint32_t c = 0; c < cpg_; c++) {
                    uint32_t gmChOff = gmGroupOff + c * HW;
                    for (uint32_t start = 0; start < HW; start += tileSize_) {
                        uint32_t len = tileSize_;
                        if (start + len > HW) len = HW - start;
                        uint32_t lenAlign = (len + 7) / 8 * 8;

                        AscendC::LocalTensor<float> inLocal = inBuf_.AllocTensor<float>();
                        AscendC::DataCopyExtParams rp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
                        AscendC::DataCopyPadExtParams<float> pp{true, 0, 0, 0.0f};
                        AscendC::DataCopyPad(inLocal, inputGm_[gmChOff + start], rp, pp);
                        inBuf_.EnQue(inLocal);
                        inLocal = inBuf_.DeQue<float>();

                        // (x - mean)^2
                        AscendC::LocalTensor<float> outLocal = outBuf_.AllocTensor<float>();
                        AscendC::Adds(outLocal, inLocal, -mean, lenAlign);
                        AscendC::PipeBarrier<PIPE_ALL>();
                        AscendC::Mul(outLocal, outLocal, outLocal, lenAlign);
                        AscendC::PipeBarrier<PIPE_ALL>();

                        // Vector reduce sum for better precision
                        AscendC::LocalTensor<float> reduceLocal2 = reduceBuf_.Get<float>();
                        AscendC::ReduceSum(outLocal, outLocal, reduceLocal2, len);
                        AscendC::PipeBarrier<PIPE_ALL>();
                        varSum += outLocal.GetValue(0);

                        outBuf_.FreeTensor(outLocal);
                        inBuf_.FreeTensor(inLocal);
                    }
                }
                float var = varSum * invCount_;
                // Compute invstd = 1/sqrt(var+eps) using vector Rsqrt on a single element
                float invstd;
                {
                    AscendC::LocalTensor<float> tmpLocal = outBuf_.AllocTensor<float>();
                    tmpLocal.SetValue(0, var + epsilon_);
                    AscendC::PipeBarrier<PIPE_ALL>();
                    AscendC::Rsqrt(tmpLocal, tmpLocal, 8);  // process 8 elements (min for alignment)
                    AscendC::PipeBarrier<PIPE_ALL>();
                    invstd = tmpLocal.GetValue(0);
                    outBuf_.FreeTensor(tmpLocal);
                }

                // Pass 3: normalize, scale by gamma, shift by beta
                for (uint32_t c = 0; c < cpg_; c++) {
                    uint32_t chIdx = g * cpg_ + c;
                    // Read gamma and beta for this channel (scalar)
                    float gam_val = 0.0f, bet_val = 0.0f;
                    {
                        AscendC::LocalTensor<float> tmpLocal = outBuf_.AllocTensor<float>();
                        AscendC::DataCopyExtParams rp1{1, (uint32_t)sizeof(float), 0, 0, 0};
                        AscendC::DataCopyPadExtParams<float> pp1{false, 0, 0, 0.0f};
                        AscendC::DataCopyPad(tmpLocal, gammaGm_[chIdx], rp1, pp1);
                        outBuf_.EnQue(tmpLocal);
                        tmpLocal = outBuf_.DeQue<float>();
                        gam_val = tmpLocal.GetValue(0);
                        outBuf_.FreeTensor(tmpLocal);
                    }
                    {
                        AscendC::LocalTensor<float> tmpLocal = outBuf_.AllocTensor<float>();
                        AscendC::DataCopyExtParams rp1{1, (uint32_t)sizeof(float), 0, 0, 0};
                        AscendC::DataCopyPadExtParams<float> pp1{false, 0, 0, 0.0f};
                        AscendC::DataCopyPad(tmpLocal, betaGm_[chIdx], rp1, pp1);
                        outBuf_.EnQue(tmpLocal);
                        tmpLocal = outBuf_.DeQue<float>();
                        bet_val = tmpLocal.GetValue(0);
                        outBuf_.FreeTensor(tmpLocal);
                    }

                    float scale = gam_val * invstd;
                    float shift = bet_val - mean * scale;

                    uint32_t gmChOff = gmGroupOff + c * HW;
                    for (uint32_t start = 0; start < HW; start += tileSize_) {
                        uint32_t len = tileSize_;
                        if (start + len > HW) len = HW - start;
                        uint32_t lenAlign = (len + 7) / 8 * 8;

                        AscendC::LocalTensor<float> inLocal = inBuf_.AllocTensor<float>();
                        AscendC::DataCopyExtParams rp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
                        AscendC::DataCopyPadExtParams<float> pp{true, 0, 0, 0.0f};
                        AscendC::DataCopyPad(inLocal, inputGm_[gmChOff + start], rp, pp);
                        inBuf_.EnQue(inLocal);
                        inLocal = inBuf_.DeQue<float>();

                        // output = (x - mean) * invstd * gamma + beta = x * scale + shift
                        AscendC::LocalTensor<float> outLocal = outBuf_.AllocTensor<float>();
                        AscendC::Muls(outLocal, inLocal, scale, lenAlign);
                        AscendC::PipeBarrier<PIPE_ALL>();
                        AscendC::Adds(outLocal, outLocal, shift, lenAlign);
                        AscendC::PipeBarrier<PIPE_ALL>();

                        AscendC::DataCopyExtParams wp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
                        AscendC::DataCopyPad(outputGm_[gmChOff + start], outLocal, wp);
                        AscendC::PipeBarrier<PIPE_ALL>();

                        outBuf_.FreeTensor(outLocal);
                        inBuf_.FreeTensor(inLocal);
                    }
                }
            }
        }
    }

private:
    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<float> inputGm_, gammaGm_, betaGm_, outputGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inBuf_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outBuf_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> reduceBuf_;
    uint32_t B_, C_, H_, W_, G_, cpg_, tileSize_;
    float epsilon_, invCount_;
};

// ============================================================================
// Kernel 6: SiLU (Vector)
// ============================================================================
class KernelSiLU {
public:
    __aicore__ inline KernelSiLU(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR input, GM_ADDR output,
                                const VecKernelTiling& t)
    {
        uint32_t totalElements = t.B * t.C * t.H * t.W;
        uint32_t coreId = AscendC::GetBlockIdx();
        if (coreId >= t.numCores) { elemCount_ = 0; return; }

        uint32_t elemsPerCore = (totalElements + t.numCores - 1) / t.numCores;
        // Align to 8 for float32
        elemsPerCore = (elemsPerCore + 7) / 8 * 8;
        startElem_ = coreId * elemsPerCore;
        uint32_t endElem = startElem_ + elemsPerCore;
        if (endElem > totalElements) endElem = totalElements;
        elemCount_ = endElem - startElem_;
        if (elemCount_ == 0) return;

        inputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(input) + startElem_, elemCount_);
        outputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(output) + startElem_, elemCount_);

        // SiLU needs src != dst, so two buffers
        constexpr uint32_t TILE = 4096;
        tileLen_ = TILE;
        pipe_->InitBuffer(inQueue_, 2, TILE * sizeof(float));
        pipe_->InitBuffer(outQueue_, 2, TILE * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        if (elemCount_ == 0) return;
        uint32_t loops = (elemCount_ + tileLen_ - 1) / tileLen_;
        for (uint32_t i = 0; i < loops; i++) {
            uint32_t len = (i == loops - 1) ? (elemCount_ - i * tileLen_) : tileLen_;
            CopyIn(i, len);
            Compute(len);
            CopyOut(i, len);
        }
    }

private:
    __aicore__ inline void CopyIn(uint32_t idx, uint32_t len)
    {
        AscendC::LocalTensor<float> inLocal = inQueue_.AllocTensor<float>();
        AscendC::DataCopyExtParams rp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
        AscendC::DataCopyPadExtParams<float> pp{false, 0, 0, 0.0f};
        AscendC::DataCopyPad(inLocal, inputGm_[idx * tileLen_], rp, pp);
        inQueue_.EnQue(inLocal);
    }

    __aicore__ inline void Compute(uint32_t len)
    {
        AscendC::LocalTensor<float> inLocal = inQueue_.DeQue<float>();
        AscendC::LocalTensor<float> outLocal = outQueue_.AllocTensor<float>();
        AscendC::Silu<float>(outLocal, inLocal, len);
        outQueue_.EnQue(outLocal);
        inQueue_.FreeTensor(inLocal);
    }

    __aicore__ inline void CopyOut(uint32_t idx, uint32_t len)
    {
        AscendC::LocalTensor<float> outLocal = outQueue_.DeQue<float>();
        AscendC::DataCopyExtParams wp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
        AscendC::DataCopyPad(outputGm_[idx * tileLen_], outLocal, wp);
        outQueue_.FreeTensor(outLocal);
    }

    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<float> inputGm_, outputGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 2> inQueue_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 2> outQueue_;
    uint32_t startElem_, elemCount_, tileLen_;
};

// ============================================================================
// Kernel 7: Residual Add (Vector)
// output = path2 + x
// ============================================================================
class KernelResidualAdd {
public:
    __aicore__ inline KernelResidualAdd(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR path2, GM_ADDR x, GM_ADDR output,
                                const VecKernelTiling& t)
    {
        uint32_t totalElements = t.B * t.C * t.H * t.W;
        uint32_t coreId = AscendC::GetBlockIdx();
        if (coreId >= t.numCores) { elemCount_ = 0; return; }

        uint32_t elemsPerCore = (totalElements + t.numCores - 1) / t.numCores;
        elemsPerCore = (elemsPerCore + 7) / 8 * 8;
        startElem_ = coreId * elemsPerCore;
        uint32_t endElem = startElem_ + elemsPerCore;
        if (endElem > totalElements) endElem = totalElements;
        elemCount_ = endElem - startElem_;
        if (elemCount_ == 0) return;

        path2Gm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(path2) + startElem_, elemCount_);
        xGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(x) + startElem_, elemCount_);
        outputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(output) + startElem_, elemCount_);

        constexpr uint32_t TILE = 4096;
        tileLen_ = TILE;
        pipe_->InitBuffer(inQueueA_, 2, TILE * sizeof(float));
        pipe_->InitBuffer(inQueueB_, 2, TILE * sizeof(float));
        pipe_->InitBuffer(outQueue_, 2, TILE * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        if (elemCount_ == 0) return;
        uint32_t loops = (elemCount_ + tileLen_ - 1) / tileLen_;
        for (uint32_t i = 0; i < loops; i++) {
            uint32_t len = (i == loops - 1) ? (elemCount_ - i * tileLen_) : tileLen_;
            CopyIn(i, len);
            Compute(len);
            CopyOut(i, len);
        }
    }

private:
    __aicore__ inline void CopyIn(uint32_t idx, uint32_t len)
    {
        AscendC::LocalTensor<float> aLocal = inQueueA_.AllocTensor<float>();
        AscendC::LocalTensor<float> bLocal = inQueueB_.AllocTensor<float>();
        AscendC::DataCopyExtParams rp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
        AscendC::DataCopyPadExtParams<float> pp{false, 0, 0, 0.0f};
        AscendC::DataCopyPad(aLocal, path2Gm_[idx * tileLen_], rp, pp);
        AscendC::DataCopyPad(bLocal, xGm_[idx * tileLen_], rp, pp);
        inQueueA_.EnQue(aLocal);
        inQueueB_.EnQue(bLocal);
    }

    __aicore__ inline void Compute(uint32_t len)
    {
        AscendC::LocalTensor<float> aLocal = inQueueA_.DeQue<float>();
        AscendC::LocalTensor<float> bLocal = inQueueB_.DeQue<float>();
        AscendC::LocalTensor<float> outLocal = outQueue_.AllocTensor<float>();
        AscendC::Add(outLocal, aLocal, bLocal, len);
        outQueue_.EnQue(outLocal);
        inQueueA_.FreeTensor(aLocal);
        inQueueB_.FreeTensor(bLocal);
    }

    __aicore__ inline void CopyOut(uint32_t idx, uint32_t len)
    {
        AscendC::LocalTensor<float> outLocal = outQueue_.DeQue<float>();
        AscendC::DataCopyExtParams wp{1, len * (uint32_t)sizeof(float), 0, 0, 0};
        AscendC::DataCopyPad(outputGm_[idx * tileLen_], outLocal, wp);
        outQueue_.FreeTensor(outLocal);
    }

    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<float> path2Gm_, xGm_, outputGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 2> inQueueA_, inQueueB_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 2> outQueue_;
    uint32_t startElem_, elemCount_, tileLen_;
};

// ============================================================================
// Kernel Entry Functions
// ============================================================================

// Copy VecKernelTiling from GM
__aicore__ inline void CopyVecTiling(VecKernelTiling* tiling, GM_ADDR tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);
    for (uint32_t i = 0; i < sizeof(VecKernelTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
}

extern "C" __global__ __vector__ void im2col_kernel(GM_ADDR input, GM_ADDR output, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    VecKernelTiling t;
    CopyVecTiling(&t, tiling);
    KernelIm2Col op(&pipe);
    op.Init(input, output, t);
    op.Process();
}

extern "C" __global__ __vector__ void weight_transpose_kernel(GM_ADDR weight, GM_ADDR weightT, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    VecKernelTiling t;
    CopyVecTiling(&t, tiling);
    KernelWeightTranspose op(&pipe);
    op.Init(weight, weightT, t);
    op.Process();
}

extern "C" __global__ __cube__ void matmul_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR c,
                                                   GM_ADDR workspace, GM_ADDR tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;
    KernelMatmul<float, float, float> mm;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), mm.mm_, &tiling);
    mm.Init(a, b, c, tiling);
    mm.Process(&pipe);
}

extern "C" __global__ __vector__ void transpose_nhwc2nchw_kernel(GM_ADDR input, GM_ADDR output, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    VecKernelTiling t;
    CopyVecTiling(&t, tiling);
    KernelTransposeNHWC2NCHW op(&pipe);
    op.Init(input, output, t);
    op.Process();
}

__aicore__ inline void CopyGNTiling(GNTilingKernel* td, GM_ADDR tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(td);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);
    for (uint32_t i = 0; i < sizeof(GNTilingKernel) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
}

extern "C" __global__ __vector__ void groupnorm_kernel(GM_ADDR input, GM_ADDR gamma, GM_ADDR beta,
                                                        GM_ADDR output, GM_ADDR workspace,
                                                        GM_ADDR tiling, GM_ADDR gnTilingGm)
{
    AscendC::TPipe pipe;
    VecKernelTiling t;
    CopyVecTiling(&t, tiling);
    GNTilingKernel gnTData;
    CopyGNTiling(&gnTData, gnTilingGm);
    KernelGroupNorm op(&pipe);
    op.Init(input, gamma, beta, output, workspace, t, gnTData);
    op.Process();
}

extern "C" __global__ __vector__ void silu_kernel(GM_ADDR input, GM_ADDR output, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    VecKernelTiling t;
    CopyVecTiling(&t, tiling);
    KernelSiLU op(&pipe);
    op.Init(input, output, t);
    op.Process();
}

extern "C" __global__ __vector__ void residual_add_kernel(GM_ADDR path2, GM_ADDR x, GM_ADDR output, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    VecKernelTiling t;
    CopyVecTiling(&t, tiling);
    KernelResidualAdd op(&pipe);
    op.Init(path2, x, output, t);
    op.Process();
}

// ============================================================================
// Host Side - Tiling Computation & Kernel Orchestration
// ============================================================================

void GenerateMatmulTiling(platform_ascendc::PlatformAscendC* platform,
                          uint32_t M, uint32_t N, uint32_t K,
                          uint8_t* tilingBuf)
{
    optiling::TCubeTiling tilingData;
    matmul_tiling::MultiCoreMatmulTiling tilingApi(*platform);
    tilingApi.SetDim(platform->GetCoreNumAic());
    tilingApi.SetAType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
                       matmul_tiling::DataType::DT_FLOAT, false);
    tilingApi.SetBType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
                       matmul_tiling::DataType::DT_FLOAT, false);
    tilingApi.SetCType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
                       matmul_tiling::DataType::DT_FLOAT);
    tilingApi.SetOrgShape(M, N, K);
    tilingApi.SetShape(M, N, K);
    tilingApi.EnableBias(false);
    tilingApi.SetBufferSpace(-1, -1, -1);
    int64_t res = tilingApi.GetTiling(tilingData);
    if (res == -1) {
        printf("ERROR: MatmulTiling failed\n");
    }
    tilingData.SaveToBuffer(tilingBuf, tilingData.GetDataSize());
}

int32_t main(int32_t argc, char* argv[])
{
    // ---- ACL Init ----
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtContext context;
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance();

    // ---- Shape parameters ----
    uint32_t B = 1, C = 256, H = 64, W = 64;
    uint32_t totalFeatureElems = B * C * H * W;
    uint32_t BHW = B * H * W;          // 4096
    uint32_t CKK = C * 9;              // 2304 (C_in * KH * KW)
    uint32_t G = 32;
    float eps = 1e-5f;

    // ---- Get core counts ----
    int64_t vectorCoreNum = 0, cubeCoreNum = 0;
    aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &vectorCoreNum);
    aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_AICORE_CORE_NUM, &cubeCoreNum);
    uint32_t vecCores = (uint32_t)vectorCoreNum;
    uint32_t cubeCores = (uint32_t)cubeCoreNum;
    // vecCores and cubeCores are determined by device

    // ---- Compute VecKernelTiling ----
    VecKernelTiling vecTiling;
    vecTiling.B = B;
    vecTiling.C = C;
    vecTiling.H = H;
    vecTiling.W = W;
    vecTiling.numCores = vecCores;
    vecTiling.KH = 3;
    vecTiling.KW = 3;
    vecTiling.pad = 1;
    vecTiling.numGroups = G;
    vecTiling.epsilon = eps;

    // Compute GroupNorm tiling (per-group: shape {1, C/G, H, W})
    // Using SaveToBuffer pattern from official groupnorm example
    optiling::GNTilingDataDef gnTilingDef;
    size_t gnTilingBufSize;
    uint8_t* gnTilingBuf;
    {
        // GroupNorm tiling: process per-group (cpg=C/G=8 channels) at a time
        // Shape {1, cpg, H, W} with isReuseSource=true requires minSize bytes of UB.
        // For {1,8,64,64}: minSize≈256KB > 192KB UB. Need to reduce per-call shape.
        // Process per-channel: shape {1, 1, H, W} with groupNum=1.
        // Then iterate over all cpg channels in the group, accumulating stats manually.
        // Actually: use shape {1, cpg, H, W} but with k sub-groups if needed.
        // Better approach: just use the API with groupNum=1, shape={1,cpg,H,W}
        // and let the tiling handle it with smaller stackBufferSize.
        // GroupNorm tiling: try multiple configurations to find one that fits in UB (192KB)
        // Config 1: per-group with shape {1, cpg, H, W}, groupNum=1
        // Config 2: per-batch with shape {1, C, H, W}, groupNum=G
        // Config 3: per-channel with shape {1, 1, H, W}, groupNum=1 (not valid for GN)
        // Test each to find one with minSize <= UB
        uint32_t cpg = C / G;  // 8
        bool isReuseSource = true;
        uint32_t maxSize = 0, minSize = 0;
        uint32_t ubBudget = 192 * 1024;  // full UB for GroupNorm's use

        // Try per-group: {1, cpg, H, W} with groupNum=1
        {
            std::vector<int64_t> sv = {1, (int64_t)cpg, (int64_t)H, (int64_t)W};
            ge::Shape s(sv);
            AscendC::GetGroupNormMaxMinTmpSize(s, sizeof(float), isReuseSource, 1, maxSize, minSize);
            // Per-group: minSize typically exceeds UB for large spatial dims
        }
        // Try per-batch: {1, C, H, W} with groupNum=G
        {
            std::vector<int64_t> sv = {1, (int64_t)C, (int64_t)H, (int64_t)W};
            ge::Shape s(sv);
            AscendC::GetGroupNormMaxMinTmpSize(s, sizeof(float), isReuseSource, G, maxSize, minSize);
            // Per-batch: also typically too large
        }
        // Use per-group shape with capped stackSize (will rely on API's internal looping)
        std::vector<int64_t> shapeVec = {1, (int64_t)cpg, (int64_t)H, (int64_t)W};
        ge::Shape srcShape(shapeVec);
        AscendC::GetGroupNormMaxMinTmpSize(srcShape, sizeof(float), isReuseSource, 1, maxSize, minSize);
        uint32_t stackSize = minSize;
        if (stackSize > ubBudget) stackSize = ubBudget;
        AscendC::GetGroupNormNDTilingInfo(srcShape, stackSize, sizeof(float), isReuseSource, 1,
                                          gnTilingDef.gnTilingData);
        // Note: GroupNorm high-level API requires minSize UB which exceeds 192KB.
        // Manual implementation is used in the kernel instead.
        // GN tiling data is still passed for epsilon and invCount parameters.
        gnTilingDef.set_groupNum(1);
        gnTilingDef.set_epsilon(eps);
        // Pass invCount (1.0 / (cpg * H * W)) via stackSize field (reinterpreted as float bits)
        float invCount = 1.0f / (float)(cpg * H * W);
        uint32_t invCountBits;
        memcpy(&invCountBits, &invCount, sizeof(uint32_t));
        gnTilingDef.set_stackSize(invCountBits);
        gnTilingBufSize = gnTilingDef.GetDataSize();
        gnTilingBuf = (uint8_t*)malloc(gnTilingBufSize);
        gnTilingDef.SaveToBuffer(gnTilingBuf, gnTilingBufSize);
    }

    // ---- Compute Matmul Tiling ----
    // Matmul: [BHW, CKK] x [CKK, C] = [BHW, C]
    size_t mmTilingSize = sizeof(TCubeTiling);
    uint8_t* mmTilingBuf = (uint8_t*)malloc(mmTilingSize);
    GenerateMatmulTiling(ascendcPlatform, BHW, C, CKK, mmTilingBuf);
    uint32_t mmNumBlocks = reinterpret_cast<TCubeTiling*>(mmTilingBuf)->usedCoreNum;
    size_t systemWorkspaceSize = (size_t)ascendcPlatform->GetLibApiWorkSpaceSize();

    // ---- Size calculations ----
    size_t featureBytes = (size_t)totalFeatureElems * sizeof(float);
    size_t colBytes = (size_t)BHW * CKK * sizeof(float);         // im2col output
    size_t wtBytes = (size_t)CKK * C * sizeof(float);            // transposed weight
    size_t mmOutBytes = (size_t)BHW * C * sizeof(float);         // matmul output
    size_t weightBytes = (size_t)C * CKK * sizeof(float);        // one conv weight
    size_t gnParamBytes = (size_t)C * sizeof(float);             // gamma or beta

    // ---- Allocate Device memory ----
    uint8_t *inputDevice = nullptr;
    uint8_t *outputDevice = nullptr;
    uint8_t *conv1WeightDevice = nullptr, *conv2WeightDevice = nullptr;
    uint8_t *norm1WeightDevice = nullptr, *norm1BiasDevice = nullptr;
    uint8_t *norm2WeightDevice = nullptr, *norm2BiasDevice = nullptr;

    // Workspace buffers on device
    uint8_t *colBufDevice = nullptr;
    uint8_t *wt1Device = nullptr, *wt2Device = nullptr;
    uint8_t *mmOutDevice = nullptr;
    uint8_t *convOutDevice = nullptr;   // after transpose NCHW
    uint8_t *path1Device = nullptr;     // after GN+SiLU stage 1
    uint8_t *mmWorkspaceDevice = nullptr;

    // VecTiling on device
    uint8_t *vecTilingDevice = nullptr;
    uint8_t *mmTilingDevice = nullptr;

    // Allocate input/output
    aclrtMalloc((void**)&inputDevice, featureBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputDevice, featureBytes, ACL_MEM_MALLOC_HUGE_FIRST);

    // Allocate weights
    aclrtMalloc((void**)&conv1WeightDevice, weightBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&conv2WeightDevice, weightBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&norm1WeightDevice, gnParamBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&norm1BiasDevice, gnParamBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&norm2WeightDevice, gnParamBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&norm2BiasDevice, gnParamBytes, ACL_MEM_MALLOC_HUGE_FIRST);

    // Allocate workspace
    aclrtMalloc((void**)&colBufDevice, colBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&wt1Device, wtBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&wt2Device, wtBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&mmOutDevice, mmOutBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&convOutDevice, featureBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&path1Device, featureBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&mmWorkspaceDevice, systemWorkspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);

    // Tiling data on device
    aclrtMalloc((void**)&vecTilingDevice, sizeof(VecKernelTiling), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(vecTilingDevice, sizeof(VecKernelTiling), &vecTiling, sizeof(VecKernelTiling), ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtMalloc((void**)&mmTilingDevice, mmTilingSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(mmTilingDevice, mmTilingSize, mmTilingBuf, mmTilingSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // GN tiling on device - using SaveToBuffer result
    uint8_t *gnTilingDevice = nullptr;
    aclrtMalloc((void**)&gnTilingDevice, gnTilingBufSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(gnTilingDevice, gnTilingBufSize, gnTilingBuf, gnTilingBufSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // ---- Load input data from files ----
    {
        uint8_t* hostBuf = nullptr;
        auto loadToDevice = [&](const char* path, uint8_t* dev, size_t sz) {
            aclrtMallocHost((void**)&hostBuf, sz);
            ReadFile(path, sz, hostBuf, sz);
            aclrtMemcpy(dev, sz, hostBuf, sz, ACL_MEMCPY_HOST_TO_DEVICE);
            aclrtFreeHost(hostBuf);
        };
        loadToDevice("./input/input_x.bin", inputDevice, featureBytes);
        loadToDevice("./input/input_norm1_weight.bin", norm1WeightDevice, gnParamBytes);
        loadToDevice("./input/input_norm1_bias.bin", norm1BiasDevice, gnParamBytes);
        loadToDevice("./input/input_norm2_weight.bin", norm2WeightDevice, gnParamBytes);
        loadToDevice("./input/input_norm2_bias.bin", norm2BiasDevice, gnParamBytes);

        // Load raw weights to device (transpose will be done by Device kernel)
        loadToDevice("./input/input_conv1_weight.bin", conv1WeightDevice, weightBytes);
        loadToDevice("./input/input_conv2_weight.bin", conv2WeightDevice, weightBytes);
    }

    // ============================================================
    // Execute Pipeline: Stage 1 (Conv1 + GN1 + SiLU1)
    // ============================================================

    // Helper macro for error checking
    #define CHECK_SYNC(name) { \
        auto _r = aclrtSynchronizeStream(stream); \
        if (_r != ACL_SUCCESS) { printf("FAIL at %s: err=%d\n", name, (int)_r); } \
        else { printf("OK: %s\n", name); } \
    }

    // 1a. Im2Col: x -> colBuf
    im2col_kernel<<<vecCores, nullptr, stream>>>(inputDevice, colBufDevice, vecTilingDevice);
    CHECK_SYNC("im2col_1");

    // 1b. WeightTranspose: conv1_weight -> wt1 (Device kernel)
    // Use at most 32 cores (256/8=32 tiles) to avoid idle-core exception
    {
        uint32_t wtCores = (C / 8 + vecCores - 1) < vecCores ? (C / 8) : vecCores;
        if (wtCores > C / 8) wtCores = C / 8;  // at most 1 core per tile
        if (wtCores == 0) wtCores = 1;
        weight_transpose_kernel<<<wtCores, nullptr, stream>>>(conv1WeightDevice, wt1Device, vecTilingDevice);
    }
    CHECK_SYNC("weight_transpose_1");

    // 1c. Matmul: colBuf x wt1 -> mmOut
    matmul_kernel<<<mmNumBlocks, nullptr, stream>>>(colBufDevice, wt1Device, mmOutDevice,
                                                     mmWorkspaceDevice, mmTilingDevice);
    CHECK_SYNC("matmul_1");

    // 1d. Transpose NHWC->NCHW: mmOut -> convOut (Device kernel)
    transpose_nhwc2nchw_kernel<<<vecCores, nullptr, stream>>>(mmOutDevice, convOutDevice, vecTilingDevice);
    CHECK_SYNC("transpose_1");

    // 1e. GroupNorm: convOut -> path1 (Device kernel)
    groupnorm_kernel<<<1, nullptr, stream>>>(convOutDevice, norm1WeightDevice, norm1BiasDevice,
                                              path1Device, nullptr, vecTilingDevice, gnTilingDevice);
    CHECK_SYNC("groupnorm_1");

    // 1f. SiLU: path1 -> convOut
    silu_kernel<<<vecCores, nullptr, stream>>>(path1Device, convOutDevice, vecTilingDevice);
    CHECK_SYNC("silu_1");

    // ============================================================
    // Execute Pipeline: Stage 2 (Conv2 + GN2 + SiLU2 + Add)
    // ============================================================

    // 2a. Im2Col: convOut(=silu1 output) -> colBuf (reuse)
    im2col_kernel<<<vecCores, nullptr, stream>>>(convOutDevice, colBufDevice, vecTilingDevice);
    CHECK_SYNC("im2col_2");

    // 2b. WeightTranspose: conv2_weight -> wt2 (Device kernel)
    {
        uint32_t wtCores = C / 8;  // 256/8=32 tiles
        if (wtCores > vecCores) wtCores = vecCores;
        if (wtCores == 0) wtCores = 1;
        weight_transpose_kernel<<<wtCores, nullptr, stream>>>(conv2WeightDevice, wt2Device, vecTilingDevice);
    }
    CHECK_SYNC("weight_transpose_2");

    // 2c. Matmul: colBuf x wt2 -> mmOut
    matmul_kernel<<<mmNumBlocks, nullptr, stream>>>(colBufDevice, wt2Device, mmOutDevice,
                                                     mmWorkspaceDevice, mmTilingDevice);
    CHECK_SYNC("matmul_2");

    // 2d. Transpose NHWC->NCHW: mmOut -> path1 (Device kernel)
    transpose_nhwc2nchw_kernel<<<vecCores, nullptr, stream>>>(mmOutDevice, path1Device, vecTilingDevice);
    CHECK_SYNC("transpose_2");

    // 2e. GroupNorm: path1 -> convOut (Device kernel)
    groupnorm_kernel<<<1, nullptr, stream>>>(path1Device, norm2WeightDevice, norm2BiasDevice,
                                              convOutDevice, nullptr, vecTilingDevice, gnTilingDevice);
    CHECK_SYNC("groupnorm_2");

    // 2f. SiLU: convOut -> path1
    silu_kernel<<<vecCores, nullptr, stream>>>(convOutDevice, path1Device, vecTilingDevice);
    CHECK_SYNC("silu_2");

    // 2g. Residual Add: path1 + x -> output
    residual_add_kernel<<<vecCores, nullptr, stream>>>(path1Device, inputDevice, outputDevice, vecTilingDevice);
    CHECK_SYNC("residual_add");

    // ---- Copy output back ----
    {
        uint8_t* outHost = nullptr;
        aclrtMallocHost((void**)&outHost, featureBytes);
        aclrtMemcpy(outHost, featureBytes, outputDevice, featureBytes, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile("./output/output.bin", outHost, featureBytes);
        aclrtFreeHost(outHost);
    }

    // ---- Cleanup ----
    aclrtFree(inputDevice);
    aclrtFree(outputDevice);
    aclrtFree(conv1WeightDevice);
    aclrtFree(conv2WeightDevice);
    aclrtFree(norm1WeightDevice);
    aclrtFree(norm1BiasDevice);
    aclrtFree(norm2WeightDevice);
    aclrtFree(norm2BiasDevice);
    aclrtFree(colBufDevice);
    aclrtFree(wt1Device);
    aclrtFree(wt2Device);
    aclrtFree(mmOutDevice);
    aclrtFree(convOutDevice);
    aclrtFree(path1Device);
    aclrtFree(mmWorkspaceDevice);
    aclrtFree(vecTilingDevice);
    aclrtFree(mmTilingDevice);
    aclrtFree(gnTilingDevice);
    free(mmTilingBuf);
    free(gnTilingBuf);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
