/*
 * Fused Softmax + Dropout Backward Kernel for Ascend C
 *
 * Computes: grad_aw = grad_awd * mask / (1-p)
 *           sum_term = sum(grad_aw * softmax_out, dim=-1)
 *           grad_scores = softmax_out * (grad_aw - sum_term)
 *
 * All inputs/outputs are float32, shape [B*H, Sq, Skv] treated as rows.
 * Each row is processed independently (Sq is the row dimension, Skv is reduced).
 */

#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t TILE_ROWS = 4;  // Rows per tile
constexpr uint32_t DOUBLE_BUFFER = 2;

struct FusedSoftmaxDropoutBwdTilingData {
    uint32_t blockNum;
    uint32_t totalRows;      // B * H * Sq
    uint32_t rowsPerCore;
    uint32_t tailRowsLastCore;
    uint32_t seqKv;           // Skv (row length)
    uint32_t seqKvAligned;    // Skv aligned to 8 (for float32)
    float invDropout;         // 1.0 / (1.0 - dropout_prob)
};

class KernelFusedSoftmaxDropoutBwd {
public:
    __aicore__ inline KernelFusedSoftmaxDropoutBwd(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(
        GM_ADDR gradAwd,    // [totalRows, seqKv] float32
        GM_ADDR mask,       // [totalRows, seqKv] bool (uint8)
        GM_ADDR softmaxOut, // [totalRows, seqKv] float32
        GM_ADDR gradScores, // [totalRows, seqKv] float32 output
        const __gm__ FusedSoftmaxDropoutBwdTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();

        uint32_t startRow, endRow;
        if (blockIdx < tiling->blockNum - 1) {
            startRow = blockIdx * tiling->rowsPerCore;
            endRow = startRow + tiling->rowsPerCore;
        } else {
            startRow = blockIdx * tiling->rowsPerCore;
            endRow = startRow + tiling->tailRowsLastCore;
        }
        this->startRow = startRow;
        this->numRows = endRow - startRow;

        uint32_t skv = tiling->seqKv;
        uint32_t skvAligned = tiling->seqKvAligned;

        uint64_t rowOffset = (uint64_t)startRow * skv;
        gradAwdGm.SetGlobalBuffer((__gm__ float*)gradAwd + rowOffset, (uint64_t)numRows * skv);
        maskGm.SetGlobalBuffer((__gm__ uint8_t*)mask + rowOffset, (uint64_t)numRows * skv);
        softmaxGm.SetGlobalBuffer((__gm__ float*)softmaxOut + rowOffset, (uint64_t)numRows * skv);
        gradScoresGm.SetGlobalBuffer((__gm__ float*)gradScores + rowOffset, (uint64_t)numRows * skv);

        // UB buffers: for each row, we need skv_aligned floats
        uint32_t rowBytes = skvAligned * sizeof(float);

        pipe_->InitBuffer(inQueueGradAwd, DOUBLE_BUFFER, rowBytes);
        pipe_->InitBuffer(inQueueSoftmax, DOUBLE_BUFFER, rowBytes);
        pipe_->InitBuffer(outQueue, DOUBLE_BUFFER, rowBytes);
        pipe_->InitBuffer(workBuf, rowBytes);  // temp for computations
        pipe_->InitBuffer(reduceBuf, 32 * 1024);  // reduce temp buffer
        pipe_->InitBuffer(scalarBuf, 32);  // scalar temp
    }

    __aicore__ inline void Process()
    {
        uint32_t skv = tiling->seqKv;
        uint32_t skvAligned = tiling->seqKvAligned;
        float invDropout = tiling->invDropout;

        for (uint32_t r = 0; r < numRows; r++) {
            // CopyIn: grad_awd and softmax_out for this row
            AscendC::LocalTensor<float> gradAwdLocal = inQueueGradAwd.AllocTensor<float>();
            AscendC::LocalTensor<float> softmaxLocal = inQueueSoftmax.AllocTensor<float>();

            AscendC::DataCopyPad(gradAwdLocal, gradAwdGm[r * skv],
                {1, static_cast<uint32_t>(skv * sizeof(float)), 0, 0},
                {false, 0, 0, 0});
            AscendC::DataCopyPad(softmaxLocal, softmaxGm[r * skv],
                {1, static_cast<uint32_t>(skv * sizeof(float)), 0, 0},
                {false, 0, 0, 0});

            inQueueGradAwd.EnQue(gradAwdLocal);
            inQueueSoftmax.EnQue(softmaxLocal);

            // Compute
            AscendC::LocalTensor<float> gawdLocal = inQueueGradAwd.DeQue<float>();
            AscendC::LocalTensor<float> smLocal = inQueueSoftmax.DeQue<float>();
            AscendC::LocalTensor<float> outLocal = outQueue.AllocTensor<float>();
            AscendC::LocalTensor<float> workLocal = workBuf.Get<float>();
            AscendC::LocalTensor<float> reduceLocal = reduceBuf.Get<float>();
            AscendC::LocalTensor<float> scalarLocal = scalarBuf.Get<float>();

            // Step 1: Apply dropout mask
            // TODO: Load bool mask and multiply. For now, assume mask is already applied
            // in the grad_awd input (we preprocess on host).
            // grad_aw = grad_awd * invDropout (mask already applied)
            AscendC::Muls<float>(gawdLocal, gawdLocal, invDropout, skv);

            // Step 2: sum_term = sum(grad_aw * softmax_out)
            AscendC::Mul<float>(workLocal, gawdLocal, smLocal, skv);
            AscendC::ReduceSum<float, true>(scalarLocal, workLocal, reduceLocal,
                static_cast<int32_t>(skv));
            float sumVal = scalarLocal.GetValue(0);

            // Step 3: grad_aw - sum_term
            AscendC::Adds<float>(gawdLocal, gawdLocal, -sumVal, skv);

            // Step 4: softmax_out * (grad_aw - sum_term)
            AscendC::Mul<float>(outLocal, smLocal, gawdLocal, skv);

            outQueue.EnQue(outLocal);
            inQueueGradAwd.FreeTensor(gawdLocal);
            inQueueSoftmax.FreeTensor(smLocal);

            // CopyOut
            AscendC::LocalTensor<float> resultLocal = outQueue.DeQue<float>();
            AscendC::DataCopyPad(gradScoresGm[r * skv], resultLocal,
                {1, static_cast<uint32_t>(skv * sizeof(float)), 0, 0});
            outQueue.FreeTensor(resultLocal);
        }
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ FusedSoftmaxDropoutBwdTilingData* tiling;

    AscendC::GlobalTensor<float> gradAwdGm;
    AscendC::GlobalTensor<uint8_t> maskGm;
    AscendC::GlobalTensor<float> softmaxGm;
    AscendC::GlobalTensor<float> gradScoresGm;

    AscendC::TQue<AscendC::TPosition::VECIN, DOUBLE_BUFFER> inQueueGradAwd;
    AscendC::TQue<AscendC::TPosition::VECIN, DOUBLE_BUFFER> inQueueSoftmax;
    AscendC::TQue<AscendC::TPosition::VECOUT, DOUBLE_BUFFER> outQueue;
    AscendC::TBuf<AscendC::TPosition::VECCALC> workBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> reduceBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> scalarBuf;

    uint32_t startRow;
    uint32_t numRows;
};

extern "C" __global__ __aicore__ void fused_softmax_dropout_bwd(
    GM_ADDR gradAwd, GM_ADDR mask, GM_ADDR softmaxOut, GM_ADDR gradScores, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelFusedSoftmaxDropoutBwd op(&pipe);
    op.Init(gradAwd, mask, softmaxOut, gradScores,
            (__gm__ FusedSoftmaxDropoutBwdTilingData*)tiling);
    op.Process();
}

// Host-side code omitted for now - will be called from Python via ctypes
